<Window x:Class="ImperialColors.UI.Views.MovimentacaoEstoqueView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Movimentação de Estoque" Width="520" Height="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary Source="/Resources/AppTheme.xaml"/>
    </Window.Resources>

    <Border Background="White" CornerRadius="8" BorderBrush="#E8E8E8" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.18" Color="#000000"/>
        </Border.Effect>

        <Grid Background="{StaticResource CinzaClaroBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border x:Name="BorderCabecalho" Grid.Row="0" Background="White" Padding="24,18" CornerRadius="8,8,0,0">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Movimentação de Estoque" FontSize="17" FontWeight="SemiBold"
                                   Foreground="{StaticResource PretoPrimarioBrush}"/>
                        <TextBlock x:Name="TxtNomeProduto" FontSize="12"
                                   Foreground="{StaticResource AmareloEscuroBrush}" Margin="0,4,0,0"
                                   FontWeight="SemiBold" TextWrapping="Wrap"/>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Top" Width="32" Height="32"
                            Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnCancelar_Click"
                            ToolTip="Fechar">
                        <TextBlock Text="✕" FontSize="14" Foreground="{StaticResource CinzaTextoBrush}"/>
                    </Button>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,12">
                <StackPanel>
                    <Border Background="#FFF8E1" CornerRadius="8" Padding="15" Margin="0,0,0,16">
                        <Grid>
                            <TextBlock Text="Estoque Atual:" FontSize="13" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtEstoqueAtual" HorizontalAlignment="Right"
                                       FontSize="18" FontWeight="Bold" Foreground="{StaticResource AmareloEscuroBrush}"/>
                        </Grid>
                    </Border>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Style="{StaticResource LabelCampo}" Text="Tipo de Movimentação *"/>
                        <ComboBox x:Name="CmbTipo" Style="{StaticResource ComboBoxModerno}">
                            <ComboBoxItem Content="Entrada" IsSelected="True"/>
                            <ComboBoxItem Content="Saída"/>
                            <ComboBoxItem Content="Ajuste"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Style="{StaticResource LabelCampo}" Text="Quantidade *"/>
                        <TextBox x:Name="TxtQuantidade" Style="{StaticResource TextBoxNumerico}" Text="0"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Style="{StaticResource LabelCampo}" Text="Motivo *"/>
                        <TextBox x:Name="TxtMotivo" Style="{StaticResource TextBoxMultilinha}" MinHeight="80"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Background="White" Padding="24,16" CornerRadius="0,0,8,8">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancelar" Style="{StaticResource BotaoSecundario}"
                            Margin="0,0,10,0" Click="BtnCancelar_Click"/>
                    <Button Content="Registrar Movimentação" Style="{StaticResource BotaoPrimario}"
                            Click="BtnSalvar_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
