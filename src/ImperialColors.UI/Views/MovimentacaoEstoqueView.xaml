<Window x:Class="ImperialColors.UI.Views.MovimentacaoEstoqueView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Movimentação de Estoque" Width="500" Height="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary Source="/Resources/AppTheme.xaml"/>
    </Window.Resources>

    <Grid Background="{StaticResource CinzaClaroBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="25,18">
            <StackPanel>
                <TextBlock Text="Movimentação de Estoque" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource PretoPrimarioBrush}"/>
                <TextBlock x:Name="TxtNomeProduto" FontSize="12"
                           Foreground="{StaticResource AmareloPrimarioBrush}" Margin="0,3,0,0"
                           FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" Margin="25,20">
            <!-- Estoque atual -->
            <Border Background="#FFF8E1" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                <Grid>
                    <TextBlock Text="Estoque Atual:" FontSize="13"/>
                    <TextBlock x:Name="TxtEstoqueAtual" HorizontalAlignment="Right"
                               FontSize="18" FontWeight="Bold" Foreground="{StaticResource AmareloPrimarioBrush}"/>
                </Grid>
            </Border>

            <!-- Tipo de movimentação -->
            <StackPanel Margin="0,0,0,12">
                <TextBlock Style="{StaticResource LabelCampo}" Text="Tipo de Movimentação *"/>
                <ComboBox x:Name="CmbTipo" Style="{StaticResource ComboBoxModerno}">
                    <ComboBoxItem Content="Entrada" IsSelected="True"/>
                    <ComboBoxItem Content="Saída"/>
                    <ComboBoxItem Content="Ajuste"/>
                </ComboBox>
            </StackPanel>

            <!-- Quantidade -->
            <StackPanel Margin="0,0,0,12">
                <TextBlock Style="{StaticResource LabelCampo}" Text="Quantidade *"/>
                <TextBox x:Name="TxtQuantidade" Style="{StaticResource TextBoxNumerico}" Text="0"/>
            </StackPanel>

            <!-- Motivo -->
            <StackPanel>
                <TextBlock Style="{StaticResource LabelCampo}" Text="Motivo *"/>
                <TextBox x:Name="TxtMotivo" Style="{StaticResource TextBoxModerno}"
                         Height="70" TextWrapping="Wrap" AcceptsReturn="True"/>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="2" Background="White" Padding="20,15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancelar" Style="{StaticResource BotaoSecundario}"
                        Margin="0,0,10,0" Click="BtnCancelar_Click"/>
                <Button Content="Registrar Movimentação" Style="{StaticResource BotaoPrimario}"
                        Click="BtnSalvar_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
