<Window x:Class="ImperialColors.UI.Views.VendaExternaFormView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:ImperialColors.UI.Converters"
        Title="Registrar Venda Externa" Width="920" Height="760"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/AppTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:MoedaConverter x:Key="MoedaConverter"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{StaticResource CinzaClaroBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="24,18">
            <StackPanel>
                <TextBlock x:Name="TxtTituloModulo" Text="Registrar Venda Externa"
                           FontSize="18" FontWeight="Bold" Foreground="{StaticResource PretoPrimarioBrush}"/>
                <TextBlock x:Name="TxtSubtituloModulo" Text="Adicione itens do estoque, digite manualmente ou importe uma lista TXT para conferência"
                           FontSize="12" Foreground="{StaticResource CinzaTextoBrush}" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20,15">
            <StackPanel>
                <StackPanel Margin="0,0,0,12">
                    <TextBlock Style="{StaticResource LabelCampo}" Text="Observações (opcional)"/>
                    <TextBox x:Name="TxtObservacoes" Style="{StaticResource TextBoxModerno}"
                             Height="56" TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"/>
                </StackPanel>

                <Border Style="{StaticResource Card}" Padding="15" Margin="0,0,0,12">
                    <StackPanel>
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="Adicionar item" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Button Content="Importar Lista (TXT)" Style="{StaticResource BotaoSecundario}"
                                    HorizontalAlignment="Right" Click="BtnImportarTxt_Click"/>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <RadioButton x:Name="RbModoEstoque" Content="Buscar no estoque"
                                         GroupName="ModoItem" IsChecked="True" Margin="0,0,20,0"
                                         Checked="ModoItem_Changed"/>
                            <RadioButton x:Name="RbModoManual" Content="Digitar manualmente"
                                         GroupName="ModoItem"
                                         Checked="ModoItem_Changed"/>
                        </StackPanel>

                        <Grid x:Name="PainelModoEstoque">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource LabelCampo}"
                                           Text="Produto (nome, código ou barras)"/>
                                <TextBox x:Name="TxtBuscaProduto" Style="{StaticResource TextBoxModerno}"
                                         TextChanged="TxtBuscaProduto_TextChanged"
                                         KeyDown="TxtBuscaProduto_KeyDown"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource LabelCampo}" Text="Quantidade"/>
                                <TextBox x:Name="TxtQuantidadeEstoque" Style="{StaticResource TextBoxNumerico}" Text="1"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Style="{StaticResource LabelCampo}" Text="Valor praticado (R$)"/>
                                <TextBox x:Name="TxtPrecoEstoque" Style="{StaticResource TextBoxNumerico}"/>
                            </StackPanel>

                            <Button Grid.Column="6" Content="+ Adicionar"
                                    Style="{StaticResource BotaoSecundario}"
                                    VerticalAlignment="Bottom" Height="36"
                                    Click="BtnAdicionarItemEstoque_Click"/>
                        </Grid>

                        <Grid x:Name="PainelModoManual" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource LabelCampo}" Text="Nome do produto *"/>
                                <TextBox x:Name="TxtNomeManual" Style="{StaticResource TextBoxModerno}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource LabelCampo}" Text="Quantidade"/>
                                <TextBox x:Name="TxtQuantidadeManual" Style="{StaticResource TextBoxNumerico}" Text="1"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Style="{StaticResource LabelCampo}" Text="Valor unitário (R$)"/>
                                <TextBox x:Name="TxtPrecoManual" Style="{StaticResource TextBoxNumerico}"/>
                            </StackPanel>

                            <Button Grid.Column="6" Content="+ Adicionar"
                                    Style="{StaticResource BotaoSecundario}"
                                    VerticalAlignment="Bottom" Height="36"
                                    Click="BtnAdicionarItemManual_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Popup x:Name="PopupResultadosProduto"
                       PlacementTarget="{Binding ElementName=TxtBuscaProduto}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       PopupAnimation="Fade">
                    <Border Background="White" CornerRadius="8"
                            BorderBrush="{StaticResource CinzaMedioBrush}" BorderThickness="1"
                            MinWidth="{Binding ActualWidth, ElementName=TxtBuscaProduto}"
                            MaxHeight="220" Margin="0,4,0,0">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.15"/>
                        </Border.Effect>
                        <ListBox x:Name="LstResultadosProduto" BorderThickness="0"
                                 MouseDoubleClick="LstResultadosProduto_MouseDoubleClick"
                                 SelectionChanged="LstResultadosProduto_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="4,2">
                                        <TextBlock Text="{Binding Nome}" FontWeight="SemiBold"/>
                                        <TextBlock FontSize="11" Foreground="{StaticResource CinzaTextoBrush}">
                                            <Run Text="{Binding CodigoInterno, Mode=OneWay}"/>
                                            <Run Text=" · Estoque: "/>
                                            <Run Text="{Binding QuantidadeEstoque, Mode=OneWay}"/>
                                            <Run Text=" "/>
                                            <Run Text="{Binding Unidade, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Popup>

                <TextBlock x:Name="TxtErroValidacao" TextWrapping="Wrap" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource VermelhoErroBrush}" Visibility="Collapsed"
                           Margin="0,0,0,12"/>

                <TextBlock Text="Grade de conferência" FontWeight="SemiBold" Margin="0,0,0,8"/>
                <Border Style="{StaticResource Card}" Padding="0">
                    <DataGrid x:Name="GridItens" Style="{StaticResource DataGridModerno}"
                              ColumnHeaderStyle="{StaticResource DataGridHeaderModerno}"
                              AutoGenerateColumns="False" CanUserAddRows="False" MinHeight="200"
                              CellEditEnding="GridItens_CellEditEnding">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tipo" Binding="{Binding TipoDescricao}" Width="80" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Cód. Barras" Binding="{Binding CodigoBarras}" Width="110" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Produto" Binding="{Binding NomeProduto}" Width="*"/>
                            <DataGridTextColumn Header="Qtd." Binding="{Binding Quantidade, StringFormat=N2}" Width="70"/>
                            <DataGridTextColumn Header="Preço Base" Binding="{Binding PrecoBase, StringFormat=N2}" Width="90" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Valor Praticado" Binding="{Binding PrecoUnitario, StringFormat=N2}" Width="110"/>
                            <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=N2}" Width="100" IsReadOnly="True"/>
                            <DataGridTemplateColumn Header="" Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="✕" Style="{StaticResource BotaoPerigo}"
                                                Padding="6,2" Click="BtnRemoverItem_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="White" Padding="20,15">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Total da venda:" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtTotalVenda" FontWeight="Bold" FontSize="18"
                               Foreground="{StaticResource AzulPrimarioBrush}" Margin="10,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancelar" Style="{StaticResource BotaoSecundario}"
                            Margin="0,0,10,0" Click="BtnCancelar_Click"/>
                    <Button x:Name="BtnAprovar" Content="Aprovar e Concluir Venda"
                            Style="{StaticResource BotaoPrimario}"
                            Click="BtnAprovar_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
