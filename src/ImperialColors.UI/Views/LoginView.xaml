<Window x:Class="ImperialColors.UI.Views.LoginView"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        Title="Imperial Colors - Acesso"

        Width="480" Height="620"

        WindowStartupLocation="CenterScreen"

        ResizeMode="NoResize"

        Background="White">



    <Window.Resources>

        <ResourceDictionary Source="/Resources/AppTheme.xaml"/>

    </Window.Resources>



    <Grid Margin="40,30">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto"/>

            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>



        <!-- Cabeçalho -->

        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,25">

            <Image x:Name="ImgLogo" Width="72" Height="72" Stretch="Uniform" Margin="0,0,0,12"/>

            <TextBlock x:Name="TxtEmpresaNome" FontSize="22" FontWeight="Bold"

                       Foreground="{StaticResource PretoPrimarioBrush}" HorizontalAlignment="Center"/>

            <TextBlock x:Name="TxtEmpresaSubtitulo" FontSize="12"

                       Foreground="{StaticResource CinzaTextoBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>

        </StackPanel>



        <!-- Abas Login / Cadastro -->

        <TabControl Grid.Row="1" BorderThickness="0" Background="Transparent">

            <TabItem Header="Entrar">

                <StackPanel Margin="0,20,0,0">

                    <TextBlock Style="{StaticResource LabelCampo}" Text="Usuário ou e-mail"/>

                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"

                             Style="{StaticResource TextBoxModerno}" Margin="0,0,0,14"/>



                    <TextBlock Style="{StaticResource LabelCampo}" Text="Senha"/>

                    <PasswordBox x:Name="TxtSenhaLogin" Style="{StaticResource PasswordBoxModerno}" Margin="0,0,0,20"
                                 KeyDown="TxtSenhaLogin_KeyDown"
                                 PasswordChanged="TxtSenhaLogin_PasswordChanged"/>



                    <Button Content="Entrar" Style="{StaticResource BotaoPrimario}"

                            Click="BtnEntrar_Click"

                            Command="{Binding LoginCommand}" Height="44" FontSize="14"/>

                </StackPanel>

            </TabItem>



            <TabItem Header="Cadastrar">

                <ScrollViewer Style="{StaticResource ScrollViewerComMargem}"

                              VerticalScrollBarVisibility="Auto"

                              Margin="0,20,0,0">

                    <StackPanel>

                        <TextBlock Style="{StaticResource LabelCampo}" Text="Nome Completo"/>

                        <TextBox Text="{Binding NomeCompleto, UpdateSourceTrigger=PropertyChanged}"

                                 Style="{StaticResource TextBoxModerno}" Margin="0,0,0,12"/>



                        <TextBlock Style="{StaticResource LabelCampo}" Text="Usuário"/>

                        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"

                                 Style="{StaticResource TextBoxModerno}" Margin="0,0,0,12"/>



                        <TextBlock Style="{StaticResource LabelCampo}" Text="E-mail"/>

                        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"

                                 Style="{StaticResource TextBoxModerno}" Margin="0,0,0,12"/>



                        <TextBlock Style="{StaticResource LabelCampo}" Text="Senha"/>

                        <PasswordBox x:Name="TxtSenhaCadastro" Style="{StaticResource PasswordBoxModerno}" Margin="0,0,0,12"
                                   PasswordChanged="TxtSenhaCadastro_PasswordChanged"/>



                        <TextBlock Style="{StaticResource LabelCampo}" Text="Confirmar Senha"/>

                        <PasswordBox x:Name="TxtConfirmarSenha" Style="{StaticResource PasswordBoxModerno}" Margin="0,0,0,16"
                                     PasswordChanged="TxtConfirmarSenha_PasswordChanged"/>



                        <TextBlock Text="Mínimo 8 caracteres, maiúscula, minúscula e número."

                                   FontSize="11" Foreground="{StaticResource CinzaTextoBrush}" Margin="0,0,0,12"/>



                        <Button Content="Criar Conta" Style="{StaticResource BotaoPrimario}"

                                Command="{Binding RegistrarCommand}" Height="44" FontSize="14"/>

                    </StackPanel>

                </ScrollViewer>

            </TabItem>

        </TabControl>

    </Grid>

</Window>


