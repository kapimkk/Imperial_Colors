<UserControl x:Class="ImperialColors.UI.Views.GestaoUsuariosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <ResourceDictionary Source="/Resources/AppTheme.xaml"/>
    </UserControl.Resources>

    <ScrollViewer Style="{StaticResource ScrollViewerComMargem}" VerticalScrollBarVisibility="Auto">
    <Grid Margin="0,0,8,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- Lista -->
        <Border Grid.Column="0" Style="{StaticResource Card}" Padding="16" Margin="0,0,10,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <Button Content="+ Novo Usuário" Style="{StaticResource BotaoPrimario}"
                            Command="{Binding NovoCommand}" Margin="0,0,10,0"/>
                    <Button Content="⟳ Atualizar" Style="{StaticResource BotaoSecundario}"
                            Command="{Binding CarregarCommand}"/>
                </StackPanel>
                <DataGrid Grid.Row="1" ItemsSource="{Binding Usuarios}"
                          SelectedItem="{Binding UsuarioSelecionado}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          Style="{StaticResource DataGridModerno}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Nome" Binding="{Binding NomeCompleto}" Width="*"/>
                        <DataGridTextColumn Header="Usuário" Binding="{Binding Username}" Width="100"/>
                        <DataGridTextColumn Header="Permissão" Binding="{Binding PermissaoDescricao}" Width="110"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding StatusDescricao}" Width="130"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Formulário -->
        <Border Grid.Column="1" Style="{StaticResource Card}" Padding="16">
            <StackPanel>
                <TextBlock Text="{Binding TituloFormulario}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,16"/>

                <TextBlock Style="{StaticResource LabelCampo}" Text="Nome Completo"/>
                <TextBox Text="{Binding NomeCompleto, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource TextBoxModerno}" Margin="0,0,0,10"/>

                <TextBlock Style="{StaticResource LabelCampo}" Text="Usuário"/>
                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         IsReadOnly="{Binding UsernameSomenteLeitura}"
                         Style="{StaticResource TextBoxModerno}" Margin="0,0,0,10"/>

                <TextBlock Style="{StaticResource LabelCampo}" Text="E-mail"/>
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource TextBoxModerno}" Margin="0,0,0,10"/>

                <TextBlock Style="{StaticResource LabelCampo}" Text="Senha"/>
                <TextBox Text="{Binding Senha, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource TextBoxModerno}" Margin="0,0,0,10"/>

                <TextBlock Style="{StaticResource LabelCampo}" Text="Permissão"/>
                <ComboBox x:Name="CmbPermissao" Margin="0,0,0,10"
                          SelectionChanged="CmbPermissao_SelectionChanged"/>

                <TextBlock Style="{StaticResource LabelCampo}" Text="Status"/>
                <ComboBox x:Name="CmbStatus" Margin="0,0,0,16"
                          SelectionChanged="CmbStatus_SelectionChanged"/>

                <Button Content="Salvar" Style="{StaticResource BotaoPrimario}"
                        Command="{Binding SalvarCommand}" Margin="0,0,0,8"/>
                <Button Content="Aprovar Selecionado" Style="{StaticResource BotaoSucesso}"
                        Command="{Binding AprovarCommand}" Margin="0,0,0,8"/>
                <Button Content="Cancelar Selecionado" Style="{StaticResource BotaoPerigo}"
                        Command="{Binding CancelarUsuarioCommand}"/>
            </StackPanel>
        </Border>
    </Grid>
    </ScrollViewer>
</UserControl>
