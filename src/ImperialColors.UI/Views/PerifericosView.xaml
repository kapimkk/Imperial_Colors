<UserControl x:Class="ImperialColors.UI.Views.PerifericosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <ResourceDictionary Source="/Resources/AppTheme.xaml"/>
    </UserControl.Resources>

    <StackPanel>
        <StackPanel Margin="0,0,0,24">
            <TextBlock Text="Impressoras" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource CinzaTextoBrush}" FontSize="12" Margin="0,0,0,12"
                       Text="Selecione a impressora usada na emissão dos cupons não fiscais."/>

            <TextBlock Style="{StaticResource LabelCampo}" Text="Impressora para Cupom"/>
            <ComboBox x:Name="CmbImpressoras" Style="{StaticResource ComboBoxModerno}" Margin="0,0,0,12"/>

            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource BotaoPrimario}" Content="Salvar Impressora"
                        Click="BtnSalvarImpressora_Click" Margin="0,0,10,0"/>
                <Button Style="{StaticResource BotaoSecundario}" Content="Atualizar Lista"
                        Click="BtnAtualizarImpressoras_Click"/>
            </StackPanel>

            <Border x:Name="PainelAvisoImpressora" Margin="0,12,0,0" Padding="12" CornerRadius="6"
                    Background="#FFF3CD" Visibility="Collapsed">
                <TextBlock x:Name="TxtAvisoImpressora" TextWrapping="Wrap" FontSize="12"/>
            </Border>
        </StackPanel>

        <Border Height="1" Background="{StaticResource CinzaMedioBrush}" Margin="0,0,0,24"/>

        <StackPanel>
            <TextBlock Text="Leitor de Código de Barras" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource CinzaTextoBrush}" FontSize="12" Margin="0,0,0,12"
                       Text="Leitores USB simulam digitação rápida + Enter. Clique no campo abaixo e bipe um produto para testar."/>

            <TextBlock Style="{StaticResource LabelCampo}" Text="Testar Leitor de Código de Barras"/>
            <TextBox x:Name="TxtTesteScanner" Style="{StaticResource TextBoxModerno}"
                     FontSize="15" KeyDown="TxtTesteScanner_KeyDown"/>

            <Border x:Name="PainelSucessoScanner" Margin="0,12,0,0" Padding="12" CornerRadius="6"
                    Background="#D4EDDA" Visibility="Collapsed">
                <TextBlock x:Name="TxtSucessoScanner" TextWrapping="Wrap" FontSize="12"
                           Foreground="#155724" FontWeight="SemiBold"/>
            </Border>
        </StackPanel>
    </StackPanel>
</UserControl>
