<UserControl x:Class="ImperialColors.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ImperialColors.UI.Converters">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/AppTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:MoedaConverter x:Key="MoedaConverter"/>
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="30,25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Cabeçalho -->
            <Grid Grid.Row="0">
                <StackPanel>
                    <TextBlock Style="{StaticResource TituloModulo}" Text="Dashboard"/>
                    <TextBlock Foreground="{StaticResource CinzaTextoBrush}" FontSize="13" Margin="0,4,0,0"
                               Text="{Binding DataHoje}"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" Style="{StaticResource BotaoSecundario}"
                        Command="{Binding CarregarCommand}" Content="⟳  Atualizar"/>
            </Grid>

            <!-- Cards de resumo -->
            <UniformGrid Grid.Row="2" Columns="4" HorizontalAlignment="Stretch">

                <!-- Vendas do dia -->
                <Border Style="{StaticResource Card}" Margin="0,0,15,0">
                    <StackPanel>
                        <TextBlock Text="VENDAS DO DIA" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource CinzaTextoBrush}"/>
                        <TextBlock Margin="0,8,0,0" FontSize="26" FontWeight="Bold"
                                   Foreground="{StaticResource PretoPrimarioBrush}"
                                   Text="{Binding TotalVendasHoje, Converter={StaticResource MoedaConverter}}"/>
                        <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="{StaticResource CinzaTextoBrush}">
                            <Run Text="{Binding QtdVendasHoje}"/>
                            <Run Text=" vendas realizadas"/>
                        </TextBlock>
                        <Border Margin="0,12,0,0" Height="3" CornerRadius="2"
                                Background="{StaticResource AmareloPrimarioBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Vendas do mês -->
                <Border Style="{StaticResource Card}" Margin="0,0,15,0">
                    <StackPanel>
                        <TextBlock Text="VENDAS DO MÊS" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource CinzaTextoBrush}"/>
                        <TextBlock Margin="0,8,0,0" FontSize="26" FontWeight="Bold"
                                   Foreground="{StaticResource PretoPrimarioBrush}"
                                   Text="{Binding TotalVendasMes, Converter={StaticResource MoedaConverter}}"/>
                        <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="{StaticResource CinzaTextoBrush}"
                                   Text="Faturamento mensal"/>
                        <Border Margin="0,12,0,0" Height="3" CornerRadius="2"
                                Background="{StaticResource VerdeSucessoBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Estoque baixo -->
                <Border Style="{StaticResource Card}" Margin="0,0,15,0">
                    <StackPanel>
                        <TextBlock Text="ESTOQUE BAIXO" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource CinzaTextoBrush}"/>
                        <TextBlock Margin="0,8,0,0" FontSize="26" FontWeight="Bold"
                                   Foreground="{StaticResource LaranjaAvisoBrush}"
                                   Text="{Binding ProdutosEstoqueBaixo}"/>
                        <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="{StaticResource CinzaTextoBrush}">
                            <Run Text="{Binding ProdutosSemEstoque}"/>
                            <Run Text=" sem estoque"/>
                        </TextBlock>
                        <Border Margin="0,12,0,0" Height="3" CornerRadius="2"
                                Background="{StaticResource LaranjaAvisoBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Clientes -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="CLIENTES" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource CinzaTextoBrush}"/>
                        <TextBlock Margin="0,8,0,0" FontSize="26" FontWeight="Bold"
                                   Foreground="{StaticResource PretoPrimarioBrush}"
                                   Text="{Binding TotalClientes}"/>
                        <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="{StaticResource CinzaTextoBrush}"
                                   Text="Cadastrados"/>
                        <Border Margin="0,12,0,0" Height="3" CornerRadius="2"
                                Background="{StaticResource AzulInfoBrush}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Segunda linha -->
            <UniformGrid Grid.Row="4" Columns="2" HorizontalAlignment="Stretch">

                <!-- Produtos com estoque baixo -->
                <Border Style="{StaticResource Card}" Margin="0,0,15,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,15">
                            <TextBlock Text="Produtos com Estoque Baixo" FontSize="15" FontWeight="SemiBold"/>
                            <Border HorizontalAlignment="Right" Style="{StaticResource BadgeAmarelo}">
                                <TextBlock Text="{Binding ProdutosEstoqueBaixo}" FontSize="12"
                                           Foreground="#856404" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding ProdutosBaixoEstoque}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="0,8" BorderBrush="{StaticResource CinzaMedioBrush}"
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Nome}" FontSize="13"/>
                                            <TextBlock Grid.Column="1" FontSize="12"
                                                       Foreground="{StaticResource LaranjaAvisoBrush}"
                                                       FontWeight="SemiBold">
                                                <Run Text="{Binding Quantidade}"/>
                                                <Run Text="{Binding Unidade}"/>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="Nenhum produto com estoque baixo"
                                   Foreground="{StaticResource CinzaTextoBrush}"
                                   FontSize="13" HorizontalAlignment="Center" Margin="0,20"
                                   Visibility="{Binding ProdutosBaixoEstoque.Count, Converter={StaticResource BoolToVisibility}}"/>
                    </StackPanel>
                </Border>

                <!-- Resumo do sistema -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Resumo do Sistema" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,15"/>

                        <Border Padding="15" CornerRadius="8" Background="{StaticResource CinzaClaroBrush}" Margin="0,0,0,10">
                            <Grid>
                                <TextBlock Text="Total de Produtos" FontSize="13"/>
                                <TextBlock HorizontalAlignment="Right" FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource PretoPrimarioBrush}"
                                           Text="{Binding TotalProdutos}"/>
                            </Grid>
                        </Border>

                        <Border Padding="15" CornerRadius="8" Background="{StaticResource CinzaClaroBrush}" Margin="0,0,0,10">
                            <Grid>
                                <TextBlock Text="Produtos Sem Estoque" FontSize="13"/>
                                <TextBlock HorizontalAlignment="Right" FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource VermelhoErroBrush}"
                                           Text="{Binding ProdutosSemEstoque}"/>
                            </Grid>
                        </Border>

                        <Border Padding="15" CornerRadius="8" Background="#FFF8E1">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="Vendas do Mês" FontSize="13"/>
                                    <TextBlock FontSize="11" Foreground="{StaticResource CinzaTextoBrush}"
                                               Text="{Binding DataHoje}"/>
                                </StackPanel>
                                <TextBlock HorizontalAlignment="Right" FontSize="18" FontWeight="Bold"
                                           Foreground="{StaticResource AmareloEscuroBrush}"
                                           VerticalAlignment="Center"
                                           Text="{Binding TotalVendasMes, Converter={StaticResource MoedaConverter}}"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </Grid>
    </ScrollViewer>
</UserControl>
