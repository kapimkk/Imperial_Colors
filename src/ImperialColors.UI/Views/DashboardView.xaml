<UserControl x:Class="ImperialColors.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ImperialColors.UI.Converters"
             xmlns:helpers="clr-namespace:ImperialColors.UI.Helpers">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/AppTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:MoedaConverter x:Key="MoedaConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  Style="{StaticResource ScrollViewerComMargem}"
                  helpers:ScrollViewerMouseWheelHelper.Habilitar="True">
        <Grid Margin="30,25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image x:Name="ImgLogoDashboard" Width="48" Height="48" Margin="0,0,16,0" Stretch="Uniform"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource TituloModulo}" Text="Dashboard"/>
                        <TextBlock x:Name="TxtEmpresaDashboard" Foreground="{StaticResource CinzaTextoBrush}"
                                   FontSize="13" Margin="0,4,0,0"/>
                        <TextBlock Foreground="{StaticResource CinzaTextoBrush}" FontSize="13"
                                   Text="{Binding DataHoje}"/>
                    </StackPanel>
                </StackPanel>
                <Button HorizontalAlignment="Right" Style="{StaticResource BotaoSecundario}"
                        Command="{Binding CarregarCommand}" Content="⟳  Atualizar"/>
            </Grid>

            <!-- KPIs — giro de estoque e faturamento -->
            <UniformGrid Grid.Row="2" Columns="4" HorizontalAlignment="Stretch">

                <Border Style="{StaticResource Card}" Margin="0,0,12,0" Padding="20,18">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠" FontSize="18" Margin="0,0,8,0"/>
                            <TextBlock Text="ESTOQUE CRÍTICO" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource CinzaTextoBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Margin="0,10,0,0" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource LaranjaAvisoBrush}"
                                   Text="{Binding ProdutosEstoqueCritico}"/>
                        <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="{StaticResource CinzaTextoBrush}"
                                   Text="Menos de 5 unidades"/>
                        <Border Margin="0,10,0,0" Height="3" CornerRadius="2"
                                Background="{StaticResource LaranjaAvisoBrush}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,12,0" Padding="20,18">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⛔" FontSize="18" Margin="0,0,8,0"/>
                            <TextBlock Text="ESTOQUE ZERADO" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource CinzaTextoBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Margin="0,10,0,0" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource VermelhoErroBrush}"
                                   Text="{Binding ProdutosSemEstoque}"/>
                        <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="{StaticResource CinzaTextoBrush}"
                                   Text="Itens sem saldo"/>
                        <Border Margin="0,10,0,0" Height="3" CornerRadius="2"
                                Background="{StaticResource VermelhoErroBrush}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,12,0" Padding="20,18">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💰" FontSize="18" Margin="0,0,8,0"/>
                            <TextBlock Text="FATURAMENTO DO DIA" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource CinzaTextoBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Margin="0,10,0,0" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource PretoPrimarioBrush}"
                                   Text="{Binding TotalVendasHoje, Converter={StaticResource MoedaConverter}}"/>
                        <Border Margin="0,14,0,0" Height="3" CornerRadius="2"
                                Background="{StaticResource AmareloPrimarioBrush}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Padding="20,18">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📈" FontSize="18" Margin="0,0,8,0"/>
                            <TextBlock Text="FATURAMENTO DO MÊS" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource CinzaTextoBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Margin="0,10,0,0" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource PretoPrimarioBrush}"
                                   Text="{Binding TotalVendasMes, Converter={StaticResource MoedaConverter}}"/>
                        <Border Margin="0,14,0,0" Height="3" CornerRadius="2"
                                Background="{StaticResource VerdeSucessoBrush}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Últimas 5 vendas -->
            <Border Grid.Row="4" Style="{StaticResource Card}" Padding="22,18">
                <StackPanel>
                    <TextBlock Text="Últimas 5 Vendas" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,14"/>
                    <DataGrid ItemsSource="{Binding UltimasVendas}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              BorderThickness="0"
                              Background="Transparent"
                              RowBackground="White"
                              AlternatingRowBackground="#F8F9FA"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              SelectionMode="Single"
                              ScrollViewer.CanContentScroll="False"
                              ScrollViewer.VerticalScrollBarVisibility="Disabled"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Hora" Binding="{Binding HoraVenda}" Width="80"/>
                            <DataGridTextColumn Header="Pagamento" Binding="{Binding FormaPagamentoDescricao}" Width="*"/>
                            <DataGridTextColumn Header="Total" Binding="{Binding Total, Converter={StaticResource MoedaConverter}}" Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="HorizontalAlignment" Value="Right"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
