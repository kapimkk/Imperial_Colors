<UserControl x:Class="ImperialColors.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ImperialColors.UI.Converters">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/AppTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:MoedaConverter x:Key="MoedaConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="30,25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image x:Name="ImgLogoDashboard" Width="48" Height="48" Margin="0,0,16,0" Stretch="Uniform"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource TituloModulo}" Text="Dashboard"/>
                        <TextBlock x:Name="TxtEmpresaDashboard" Foreground="{StaticResource CinzaTextoBrush}"
                                   FontSize="13" Margin="0,4,0,0"/>
                        <TextBlock Foreground="{StaticResource CinzaTextoBrush}" FontSize="13"
                                   Text="{Binding DataHoje}"/>
                    </StackPanel>
                </StackPanel>
                <Button HorizontalAlignment="Right" Style="{StaticResource BotaoSecundario}"
                        Command="{Binding CarregarCommand}" Content="⟳  Atualizar"/>
            </Grid>

            <!-- KPIs -->
            <UniformGrid Grid.Row="2" Columns="4" HorizontalAlignment="Stretch">

                <Border Style="{StaticResource Card}" Margin="0,0,12,0" Padding="20,18">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💰" FontSize="18" Margin="0,0,8,0"/>
                            <TextBlock Text="FATURAMENTO DO DIA" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource CinzaTextoBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Margin="0,10,0,0" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource PretoPrimarioBrush}"
                                   Text="{Binding TotalVendasHoje, Converter={StaticResource MoedaConverter}}"/>
                        <Border Margin="0,14,0,0" Height="3" CornerRadius="2"
                                Background="{StaticResource AmareloPrimarioBrush}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,12,0" Padding="20,18">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📈" FontSize="18" Margin="0,0,8,0"/>
                            <TextBlock Text="FATURAMENTO DO MÊS" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource CinzaTextoBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Margin="0,10,0,0" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource PretoPrimarioBrush}"
                                   Text="{Binding TotalVendasMes, Converter={StaticResource MoedaConverter}}"/>
                        <Border Margin="0,14,0,0" Height="3" CornerRadius="2"
                                Background="{StaticResource VerdeSucessoBrush}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,0,12,0" Padding="20,18">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠" FontSize="18" Margin="0,0,8,0"/>
                            <TextBlock Text="ALERTA CRÍTICO" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource CinzaTextoBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Margin="0,10,0,0" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource LaranjaAvisoBrush}"
                                   Text="{Binding AlertasEstoqueCritico}"/>
                        <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="{StaticResource CinzaTextoBrush}"
                                   Text="Itens baixo / zerado"/>
                        <Border Margin="0,10,0,0" Height="3" CornerRadius="2"
                                Background="{StaticResource LaranjaAvisoBrush}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Padding="20,18">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👥" FontSize="18" Margin="0,0,8,0"/>
                            <TextBlock Text="CLIENTES ATIVOS" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource CinzaTextoBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Margin="0,10,0,0" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource PretoPrimarioBrush}"
                                   Text="{Binding TotalClientes}"/>
                        <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="{StaticResource CinzaTextoBrush}"
                                   Text="Cadastrados no sistema"/>
                        <Border Margin="0,10,0,0" Height="3" CornerRadius="2"
                                Background="{StaticResource AzulInfoBrush}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Top 3 produtos do mês -->
            <Border Grid.Row="4" Style="{StaticResource Card}" Padding="22,18" MaxWidth="520" HorizontalAlignment="Left">
                <StackPanel>
                    <TextBlock Text="Top 3 Produtos do Mês" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,14"/>
                    <ItemsControl ItemsSource="{Binding TopProdutosMes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding NomeProduto}" FontSize="13"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <TextBlock FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right"
                                                   Text="{Binding TotalVendido, Converter={StaticResource MoedaConverter}}"/>
                                        <TextBlock FontSize="11" Foreground="{StaticResource CinzaTextoBrush}" HorizontalAlignment="Right">
                                            <Run Text="{Binding QuantidadeTotal, StringFormat={}{0:G}}"/>
                                            <Run Text=" un."/>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
