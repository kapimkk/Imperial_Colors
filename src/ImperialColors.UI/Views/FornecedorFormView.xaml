<Window x:Class="ImperialColors.UI.Views.FornecedorFormView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fornecedor" Width="640" Height="660"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary Source="/Resources/AppTheme.xaml"/>
    </Window.Resources>

    <Border Background="White" CornerRadius="8" BorderBrush="#E8E8E8" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.18" Color="#000000"/>
        </Border.Effect>

        <Grid Background="{StaticResource CinzaClaroBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border x:Name="BorderCabecalho" Grid.Row="0" Background="White" Padding="24,18" CornerRadius="8,8,0,0">
                <Grid>
                    <TextBlock x:Name="TxtTitulo" Text="Novo Fornecedor" FontSize="17" FontWeight="SemiBold"
                               VerticalAlignment="Center" Foreground="{StaticResource PretoPrimarioBrush}"/>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" Width="32" Height="32"
                            Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnFechar_Click"
                            ToolTip="Fechar">
                        <TextBlock Text="✕" FontSize="14" Foreground="{StaticResource CinzaTextoBrush}"/>
                    </Button>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" Padding="24,8,24,8" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource LabelCampo}" Text="CNPJ"/>
                            <TextBox x:Name="TxtCnpj" Style="{StaticResource TextBoxModerno}"
                                     MaxLength="18" TextChanged="TxtCnpj_TextChanged"/>
                        </StackPanel>
                        <Button Grid.Column="2" VerticalAlignment="Bottom" Style="{StaticResource BotaoSecundario}"
                                Padding="16,10" Click="BtnBuscarCnpj_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔍" Margin="0,0,6,0"/>
                                <TextBlock Text="Buscar"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Style="{StaticResource LabelCampo}" Text="Razão Social / Nome *"/>
                        <TextBox x:Name="TxtNome" Style="{StaticResource TextBoxModerno}"/>
                    </StackPanel>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/><ColumnDefinition Width="15"/><ColumnDefinition/><ColumnDefinition Width="15"/><ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource LabelCampo}" Text="Telefone"/>
                            <TextBox x:Name="TxtTelefone" Style="{StaticResource TextBoxModerno}"
                                     MaxLength="16" TextChanged="TxtTelefone_TextChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource LabelCampo}" Text="WhatsApp"/>
                            <TextBox x:Name="TxtWhatsApp" Style="{StaticResource TextBoxModerno}"
                                     MaxLength="16" TextChanged="TxtWhatsApp_TextChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Style="{StaticResource LabelCampo}" Text="E-mail"/>
                            <TextBox x:Name="TxtEmail" Style="{StaticResource TextBoxModerno}"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/><ColumnDefinition Width="12"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource LabelCampo}" Text="CEP"/>
                            <TextBox x:Name="TxtCep" Style="{StaticResource TextBoxModerno}"
                                     MaxLength="9" TextChanged="TxtCep_TextChanged"/>
                        </StackPanel>
                        <Button Grid.Column="2" VerticalAlignment="Bottom" Style="{StaticResource BotaoSecundario}"
                                Padding="16,10" Click="BtnBuscarCep_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔍" Margin="0,0,6,0"/>
                                <TextBlock Text="Buscar"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/><ColumnDefinition Width="15"/><ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource LabelCampo}" Text="Logradouro"/>
                            <TextBox x:Name="TxtLogradouro" Style="{StaticResource TextBoxModerno}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource LabelCampo}" Text="Nº"/>
                            <TextBox x:Name="TxtNumero" Style="{StaticResource TextBoxModerno}"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/><ColumnDefinition Width="15"/><ColumnDefinition/>
                            <ColumnDefinition Width="15"/><ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="15"/><ColumnDefinition Width="72"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Style="{StaticResource LabelCampo}" Text="Complemento"/>
                            <TextBox x:Name="TxtComplemento" Style="{StaticResource TextBoxModerno}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource LabelCampo}" Text="Bairro"/>
                            <TextBox x:Name="TxtBairro" Style="{StaticResource TextBoxModerno}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="4">
                            <TextBlock Style="{StaticResource LabelCampo}" Text="Cidade"/>
                            <TextBox x:Name="TxtCidade" Style="{StaticResource TextBoxModerno}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="6">
                            <TextBlock Style="{StaticResource LabelCampo}" Text="UF"/>
                            <TextBox x:Name="TxtEstado" Style="{StaticResource TextBoxModerno}"
                                     MinWidth="64" MaxLength="2" CharacterCasing="Upper"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel>
                        <TextBlock Style="{StaticResource LabelCampo}" Text="Observações"/>
                        <TextBox x:Name="TxtObservacoes" Style="{StaticResource TextBoxModerno}"
                                 Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Row="2" Background="#FAFAFA" Padding="24,8">
                <TextBlock x:Name="TxtStatus" FontSize="12" Foreground="{StaticResource CinzaTextoBrush}"/>
            </Border>

            <Border Grid.Row="3" Background="White" Padding="24,16" CornerRadius="0,0,8,8">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancelar" Style="{StaticResource BotaoSecundario}" Margin="0,0,10,0" Click="BtnCancelar_Click"/>
                    <Button Content="Salvar" Style="{StaticResource BotaoPrimario}" Click="BtnSalvar_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
