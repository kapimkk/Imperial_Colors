<Window x:Class="ImperialColors.UI.Views.ListaCompraFormView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lista de Compras" Width="780" Height="680"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/AppTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <DataTemplate x:Key="ComboBoxNomeTemplate">
                <TextBlock Text="{Binding Nome}" FontSize="13"/>
            </DataTemplate>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{StaticResource CinzaClaroBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="24,18">
            <StackPanel>
                <TextBlock x:Name="TxtTitulo" Text="Nova Lista de Compras"
                           FontSize="18" FontWeight="Bold" Foreground="{StaticResource PretoPrimarioBrush}"/>
                <TextBlock Text="Monte a lista de produtos para comprar do fornecedor"
                           FontSize="12" Foreground="{StaticResource CinzaTextoBrush}" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20,15">
            <StackPanel>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="15"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource LabelCampo}" Text="Nome da Lista *"/>
                        <TextBox x:Name="TxtNome" Style="{StaticResource TextBoxModerno}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource LabelCampo}" Text="Fornecedor (opcional)"/>
                        <ComboBox x:Name="CmbFornecedor" Style="{StaticResource ComboBoxModerno}"
                                  SelectedValuePath="Id"
                                  ItemTemplate="{StaticResource ComboBoxNomeTemplate}"/>
                    </StackPanel>
                </Grid>

                <StackPanel Margin="0,0,0,12">
                    <TextBlock Style="{StaticResource LabelCampo}" Text="Observações"/>
                    <TextBox x:Name="TxtObservacoes" Style="{StaticResource TextBoxModerno}"
                             Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"/>
                </StackPanel>

                <Border Style="{StaticResource Card}" Padding="15" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Adicionar item" FontWeight="SemiBold" Margin="0,0,0,12"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <RadioButton x:Name="RbModoEstoque" Content="Buscar no estoque"
                                         GroupName="ModoItem" IsChecked="True" Margin="0,0,20,0"
                                         Checked="ModoItem_Changed"/>
                            <RadioButton x:Name="RbModoManual" Content="Digitar manualmente"
                                         GroupName="ModoItem"
                                         Checked="ModoItem_Changed"/>
                        </StackPanel>

                        <!-- Modo estoque -->
                        <Grid x:Name="PainelModoEstoque">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource LabelCampo}"
                                           Text="Produto do estoque (nome, código ou barras)"/>
                                <TextBox x:Name="TxtBuscaProduto" Style="{StaticResource TextBoxModerno}"
                                         TextChanged="TxtBuscaProduto_TextChanged"
                                         KeyDown="TxtBuscaProduto_KeyDown"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource LabelCampo}" Text="Quantidade"/>
                                <TextBox x:Name="TxtQuantidadeEstoque" Style="{StaticResource TextBoxNumerico}" Text="1"/>
                            </StackPanel>

                            <Button Grid.Column="4" Content="+ Adicionar"
                                    Style="{StaticResource BotaoSecundario}"
                                    VerticalAlignment="Bottom" Height="36"
                                    Click="BtnAdicionarItemEstoque_Click"/>
                        </Grid>

                        <!-- Modo manual -->
                        <Grid x:Name="PainelModoManual" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource LabelCampo}" Text="Descrição do item *"/>
                                <TextBox x:Name="TxtDescricaoManual" Style="{StaticResource TextBoxModerno}"
                                         ToolTip="Ex.: Tinta acrílica 18L cor especial"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource LabelCampo}" Text="Quantidade"/>
                                <TextBox x:Name="TxtQuantidadeManual" Style="{StaticResource TextBoxNumerico}" Text="1"/>
                            </StackPanel>

                            <Button Grid.Column="4" Content="+ Adicionar"
                                    Style="{StaticResource BotaoSecundario}"
                                    VerticalAlignment="Bottom" Height="36"
                                    Click="BtnAdicionarItemManual_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Popup x:Name="PopupResultadosProduto"
                       PlacementTarget="{Binding ElementName=TxtBuscaProduto}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       PopupAnimation="Fade">
                    <Border Background="White" CornerRadius="8"
                            BorderBrush="{StaticResource CinzaMedioBrush}" BorderThickness="1"
                            MinWidth="{Binding ActualWidth, ElementName=TxtBuscaProduto}"
                            MaxHeight="220" Margin="0,4,0,0">
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.15"/>
                        </Border.Effect>
                        <ListBox x:Name="LstResultadosProduto" BorderThickness="0"
                                 MouseDoubleClick="LstResultadosProduto_MouseDoubleClick"
                                 SelectionChanged="LstResultadosProduto_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="4,2">
                                        <TextBlock Text="{Binding Nome}" FontWeight="SemiBold"/>
                                        <TextBlock FontSize="11" Foreground="{StaticResource CinzaTextoBrush}">
                                            <Run Text="{Binding CodigoInterno, Mode=OneWay}"/>
                                            <Run Text=" · Estoque: "/>
                                            <Run Text="{Binding QuantidadeEstoque, Mode=OneWay}"/>
                                            <Run Text=" "/>
                                            <Run Text="{Binding Unidade, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Popup>

                <TextBlock x:Name="TxtErroValidacao" TextWrapping="Wrap" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource VermelhoErroBrush}" Visibility="Collapsed"
                           Margin="0,0,0,12"/>

                <Border Style="{StaticResource Card}" Padding="0">
                    <DataGrid x:Name="GridItens" Style="{StaticResource DataGridModerno}"
                              ColumnHeaderStyle="{StaticResource DataGridHeaderModerno}"
                              AutoGenerateColumns="False" CanUserAddRows="False" MinHeight="180">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Produto" Binding="{Binding NomeProduto}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Origem" Binding="{Binding OrigemDescricao}" Width="90" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Qtd. Desejada" Binding="{Binding QuantidadeDesejada, StringFormat=N1}" Width="110"/>
                            <DataGridTextColumn Header="Qtd. Comprada" Binding="{Binding QuantidadeComprada, StringFormat=N1}" Width="110"/>
                            <DataGridCheckBoxColumn Header="Comprado" Binding="{Binding Comprado}" Width="90"/>
                            <DataGridTemplateColumn Header="" Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="✕" Style="{StaticResource BotaoPerigo}"
                                                Padding="6,2" Click="BtnRemoverItem_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="White" Padding="20,15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancelar" Style="{StaticResource BotaoSecundario}"
                        Margin="0,0,10,0" Click="BtnCancelar_Click"/>
                <Button x:Name="BtnSalvar" Content="Salvar Lista" Style="{StaticResource BotaoPrimario}"
                        Click="BtnSalvar_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
