<Window x:Class="ImperialColors.UI.Views.TrocaFormView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Registrar Troca" Width="680" Height="730"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/AppTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{StaticResource CinzaClaroBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="White" Padding="25,18">
            <StackPanel>
                <TextBlock Text="Registrar Troca de Produto" FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource PretoPrimarioBrush}"/>
                <TextBlock x:Name="TxtSubtitulo" FontSize="12" Margin="0,3,0,0"
                           Foreground="{StaticResource CinzaTextoBrush}"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20,12">
            <StackPanel>

                <!-- ETAPA 1: Item Devolvido -->
                <Border Style="{StaticResource Card}" Padding="18" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="① Item Devolvido pelo Cliente" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource PretoPrimarioBrush}" Margin="0,0,0,14"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource LabelCampo}" Text="Produto da Venda *"/>
                                <ComboBox x:Name="CmbItemOrigem" Style="{StaticResource ComboBoxModerno}"
                                          SelectionChanged="CmbItemOrigem_SelectionChanged">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding NomeExibicao}" FontSize="13"
                                                       TextWrapping="Wrap"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource LabelCampo}" Text="Qtd. Devolvida *"/>
                                <TextBox x:Name="TxtQtdDevolvida" Style="{StaticResource TextBoxNumerico}" Text="1"
                                         TextChanged="Valores_Changed"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock x:Name="TxtInfoItemDevolvido" FontSize="12" Margin="0,8,0,0"
                                   Foreground="{StaticResource CinzaTextoBrush}" TextWrapping="Wrap"/>

                        <!-- Checkbox retornar ao estoque -->
                        <Border Background="#F0F8FF" CornerRadius="6" Padding="12,10" Margin="0,12,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox x:Name="ChkRetornarEstoque" Grid.Column="0"
                                          VerticalAlignment="Center" IsChecked="True"
                                          Checked="Valores_Changed" Unchecked="Valores_Changed"/>
                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                    <TextBlock Text="Retornar item devolvido para o estoque físico?"
                                               FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="Marque quando a lata estiver lacrada/não aberta."
                                               FontSize="11" Foreground="{StaticResource CinzaTextoBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ETAPA 2: Novo Item -->
                <Border Style="{StaticResource Card}" Padding="18" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="② Novo Item Escolhido pelo Cliente" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource PretoPrimarioBrush}" Margin="0,0,0,14"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource LabelCampo}"
                                           Text="Buscar produto (nome, código ou código de barras) *"/>
                                <Grid>
                                    <TextBox x:Name="TxtBuscaNovoProduto" Style="{StaticResource TextBoxModerno}"
                                             TextChanged="TxtBuscaNovoProduto_TextChanged"
                                             KeyDown="TxtBuscaNovoProduto_KeyDown"
                                             ToolTip="Digite ou use um leitor de código de barras"/>
                                    <Popup x:Name="PopupResultados" PlacementTarget="{Binding ElementName=TxtBuscaNovoProduto}"
                                           Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
                                           PopupAnimation="Fade">
                                        <Border Background="White"
                                                BorderBrush="{DynamicResource CinzaMedioBrush}" BorderThickness="1"
                                                CornerRadius="8" MaxHeight="200" Margin="0,4,0,0">
                                            <Border.Effect>
                                                <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.15"/>
                                            </Border.Effect>
                                            <ListBox x:Name="LstResultados" MaxHeight="200"
                                                     SelectionChanged="LstResultados_SelectionChanged"
                                                     MouseDoubleClick="LstResultados_MouseDoubleClick"
                                                     BorderThickness="0">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="4,3">
                                                            <TextBlock Text="{Binding NomeExibicao}" FontWeight="SemiBold" FontSize="13"/>
                                                            <TextBlock FontSize="11" Foreground="{DynamicResource CinzaTextoBrush}">
                                                                <Run Text="{Binding CodigoInterno}"/>
                                                                <Run Text=" | Estoque: "/>
                                                                <Run Text="{Binding QuantidadeEstoque}"/>
                                                                <Run Text=" "/>
                                                                <Run Text="{Binding Unidade}"/>
                                                                <Run Text=" | R$ "/>
                                                                <Run Text="{Binding PrecoVenda, StringFormat=N2}"/>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Border>
                                    </Popup>
                                </Grid>
                                <TextBlock x:Name="TxtInfoNovoProduto" FontSize="12" Margin="0,4,0,0"
                                           Foreground="{DynamicResource AzulPrimarioBrush}" TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource LabelCampo}" Text="Quantidade *"/>
                                <TextBox x:Name="TxtQtdNova" Style="{StaticResource TextBoxNumerico}" Text="1"
                                         TextChanged="Valores_Changed"/>
                            </StackPanel>
                        </Grid>

                        <!-- Preço novo produto -->
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource LabelCampo}" Text="Preço Unitário do Novo Item"/>
                                <TextBox x:Name="TxtPrecoNovoProduto" Style="{StaticResource TextBoxNumerico}"
                                         TextChanged="Valores_Changed" IsReadOnly="True"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" VerticalAlignment="Bottom" Margin="12,0,0,6"
                                       FontSize="11" Foreground="{StaticResource CinzaTextoBrush}"
                                       Text="Preenchido automaticamente ao selecionar o produto."/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ETAPA 3: Resumo Financeiro -->
                <Border Style="{StaticResource Card}" Padding="18" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="③ Resumo Financeiro" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource PretoPrimarioBrush}" Margin="0,0,0,14"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="Total Item Devolvido" Style="{StaticResource LabelCampo}"/>
                                <TextBlock x:Name="TxtTotalDevolvido" FontSize="18" FontWeight="Bold"
                                           Foreground="{StaticResource CinzaTextoBrush}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="Total Novo Item" Style="{StaticResource LabelCampo}"/>
                                <TextBlock x:Name="TxtTotalNovo" FontSize="18" FontWeight="Bold"
                                           Foreground="{DynamicResource AzulPrimarioBrush}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Saldo da Troca -->
                        <Border x:Name="BordaDiferenca" CornerRadius="8" Padding="16,12" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock x:Name="TxtDiferencaLabel" FontSize="13" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TxtDiferencaValor" FontSize="28" FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Forma de pagamento (visível apenas quando há diferença a receber) -->
                        <StackPanel x:Name="PainelFormaPagamento" Margin="0,14,0,0" Visibility="Collapsed">
                            <TextBlock Style="{StaticResource LabelCampo}" Text="Forma de Pagamento da Diferença *"/>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <RadioButton x:Name="RbDinheiro" Content="💵 Dinheiro" GroupName="FormaPgto"
                                             Margin="0,0,16,0" FontSize="13" IsChecked="True"/>
                                <RadioButton x:Name="RbPix" Content="📱 Pix" GroupName="FormaPgto"
                                             Margin="0,0,16,0" FontSize="13"/>
                                <RadioButton x:Name="RbCartaoDebito" Content="💳 Débito" GroupName="FormaPgto"
                                             Margin="0,0,16,0" FontSize="13"/>
                                <RadioButton x:Name="RbCartaoCredito" Content="💳 Crédito" GroupName="FormaPgto"
                                             FontSize="13"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Erro / Validação -->
                <TextBlock x:Name="TxtErro" TextWrapping="Wrap" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource VermelhoErroBrush}" Visibility="Collapsed"
                           Margin="0,0,0,10"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Rodapé -->
        <Border Grid.Row="2" Background="White" Padding="20,15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancelar" Style="{StaticResource BotaoSecundario}"
                        Margin="0,0,10,0" Click="BtnCancelar_Click"/>
                <Button x:Name="BtnConfirmar" Content="✔ Confirmar Troca"
                        Style="{StaticResource BotaoPrimario}" Click="BtnConfirmar_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
