<UserControl x:Class="ImperialColors.UI.Views.MercadoriasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <ResourceDictionary Source="/Resources/AppTheme.xaml"/>
    </UserControl.Resources>

    <Grid Margin="30,25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <StackPanel>
                <TextBlock Style="{StaticResource TituloModulo}" Text="Fornecedores"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Style="{StaticResource BotaoSecundario}" Command="{Binding EditarFornecedorCommand}"
                        Margin="0,0,10,0" Content="✏  Editar"/>
                <Button Style="{StaticResource BotaoPerigo}" Command="{Binding ExcluirFornecedorCommand}"
                        Margin="0,0,10,0" Content="🗑  Excluir"/>
                <Button Style="{StaticResource BotaoPrimario}" Command="{Binding NovoFornecedorCommand}"
                        Content="+ Novo Fornecedor"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="15">
            <TextBox Style="{StaticResource TextBoxFiltro}"
                     Text="{Binding TermoBusca, UpdateSourceTrigger=PropertyChanged}"/>
        </Border>

        <Border Grid.Row="4" Style="{StaticResource Card}" Padding="0">
            <DataGrid Style="{StaticResource DataGridModerno}" ColumnHeaderStyle="{StaticResource DataGridHeaderModerno}"
                      ItemsSource="{Binding Fornecedores}" SelectedItem="{Binding FornecedorSelecionado}"
                      MouseDoubleClick="DataGrid_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="*"/>
                    <DataGridTextColumn Header="Telefone" Binding="{Binding Telefone}" Width="130"/>
                    <DataGridTextColumn Header="WhatsApp" Binding="{Binding WhatsApp}" Width="130"/>
                    <DataGridTextColumn Header="E-mail" Binding="{Binding Email}" Width="180"/>
                    <DataGridTextColumn Header="Cidade" Binding="{Binding Cidade}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="5" Style="{StaticResource Card}" Padding="12,8" Margin="0,10,0,0">
            <Grid>
                <TextBlock VerticalAlignment="Center" Foreground="{StaticResource CinzaTextoBrush}"
                           Text="{Binding InfoPaginacao}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource BotaoSecundario}" Content="◀ Anterior"
                            Command="{Binding PaginaAnteriorCommand}" Margin="0,0,8,0"/>
                    <Button Style="{StaticResource BotaoSecundario}" Content="Próxima ▶"
                            Command="{Binding PaginaProximaCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
