<Window x:Class="ImperialColors.UI.Views.FechamentoVendaView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fechamento de Venda — Pagamento"
        Width="620" Height="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="White">

    <Window.Resources>
        <ResourceDictionary Source="/Resources/AppTheme.xaml"/>
    </Window.Resources>

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="Etapa 3 — Composição de Pagamentos" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource PretoPrimarioBrush}"/>
            <TextBlock Text="Adicione uma ou mais formas de pagamento até cobrir o total da venda."
                       FontSize="12" Foreground="{StaticResource CinzaTextoBrush}" Margin="0,6,0,0"/>
        </StackPanel>

        <Border Grid.Row="1" Background="{StaticResource PretoPrimarioBrush}" CornerRadius="10"
                Padding="16" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="TOTAL DA VENDA" FontSize="10" Foreground="#CCFFFFFF"/>
                    <TextBlock x:Name="TxtTotal" FontSize="22" FontWeight="Bold" Foreground="White"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="TOTAL PAGO" FontSize="10" Foreground="#CCFFFFFF"/>
                    <TextBlock x:Name="TxtTotalPago" FontSize="22" FontWeight="Bold" Foreground="White"/>
                </StackPanel>
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="SALDO RESTANTE" FontSize="10" Foreground="#CCFFFFFF"/>
                    <TextBlock x:Name="TxtSaldoRestante" FontSize="22" FontWeight="Bold" Foreground="White"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0" Margin="0,0,0,12">
            <DataGrid x:Name="DgPagamentos" AutoGenerateColumns="False" CanUserAddRows="False"
                      HeadersVisibility="Column" IsReadOnly="True" BorderThickness="0"
                      GridLinesVisibility="Horizontal">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Forma" Binding="{Binding Descricao}" Width="*"/>
                    <DataGridTextColumn Header="Valor" Binding="{Binding ValorFormatado}" Width="100"/>
                    <DataGridTextColumn Header="Troco" Binding="{Binding TrocoFormatado}" Width="80"/>
                    <DataGridTemplateColumn Header="" Width="40">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="✕" Style="{StaticResource BotaoPerigo}" Padding="4,2"
                                        Click="BtnRemoverPagamento_Click" Tag="{Binding}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="14" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Style="{StaticResource LabelCampo}" Text="Adicionar forma de pagamento" Margin="0,0,0,10"/>
                <UniformGrid Columns="3" Margin="0,0,0,12">
                    <ToggleButton x:Name="BtnDinheiro" Tag="Dinheiro" Style="{StaticResource TogglePagamento}"
                                  Margin="0,0,6,6" Click="FormaPagamento_Click" Content="💵 Dinheiro"/>
                    <ToggleButton x:Name="BtnPix" Tag="Pix" Style="{StaticResource TogglePagamento}"
                                  Margin="3,0,3,6" Click="FormaPagamento_Click" Content="📱 Pix"/>
                    <ToggleButton x:Name="BtnDebito" Tag="CartaoDebito" Style="{StaticResource TogglePagamento}"
                                  Margin="6,0,0,6" Click="FormaPagamento_Click" Content="💳 Débito"/>
                    <ToggleButton x:Name="BtnCredito" Tag="CartaoCredito" Style="{StaticResource TogglePagamento}"
                                  Margin="0,0,6,0" Click="FormaPagamento_Click" Content="💳 Crédito"/>
                    <ToggleButton x:Name="BtnBoleto" Tag="Boleto" Style="{StaticResource TogglePagamento}"
                                  Margin="3,0,3,0" Click="FormaPagamento_Click" Content="📄 Boleto"/>
                </UniformGrid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource LabelCampo}" Text="Valor deste pagamento (R$)"/>
                        <TextBox x:Name="TxtValorPagamento" Style="{StaticResource TextBoxNumerico}"
                                 TextChanged="TxtValorPagamento_TextChanged"/>
                    </StackPanel>
                    <StackPanel x:Name="PainelRecebido" Grid.Column="2" Visibility="Collapsed">
                        <TextBlock Style="{StaticResource LabelCampo}" Text="Valor recebido em espécie (R$)"/>
                        <TextBox x:Name="TxtValorRecebido" Style="{StaticResource TextBoxNumerico}"
                                 TextChanged="TxtValorRecebido_TextChanged"/>
                    </StackPanel>
                    <StackPanel x:Name="PainelParcelas" Grid.Column="2" Visibility="Collapsed">
                        <TextBlock Style="{StaticResource LabelCampo}" Text="Parcelas"/>
                        <ComboBox x:Name="CmbParcelas" Style="{StaticResource ComboBoxModerno}"/>
                    </StackPanel>
                </Grid>

                <TextBlock x:Name="TxtInfoTroco" Margin="0,8,0,0" FontSize="11"
                           Foreground="{StaticResource VerdeSucessoBrush}" Visibility="Collapsed"/>

                <Button Style="{StaticResource BotaoSecundario}" Content="+ Adicionar pagamento"
                        HorizontalAlignment="Left" Margin="0,12,0,0" Click="BtnAdicionarPagamento_Click"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Style="{StaticResource BotaoSecundario}" Content="Voltar"
                    Width="120" Margin="0,0,10,0" Click="BtnCancelar_Click"/>
            <Button x:Name="BtnConfirmar" Style="{StaticResource BotaoPrimario}" Content="Concluir Venda"
                    Width="160" IsEnabled="False" Click="BtnConfirmar_Click"/>
        </StackPanel>
    </Grid>
</Window>
