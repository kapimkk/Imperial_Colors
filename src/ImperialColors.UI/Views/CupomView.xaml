<Window x:Class="ImperialColors.UI.Views.CupomView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:ImperialColors.UI.Converters"
        Title="Cupom da Venda" Width="440" Height="650"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize" ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/AppTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:MoedaConverter x:Key="MoedaConverter"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{StaticResource CinzaClaroBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Margin="20,20,20,10">
            <!-- Área do cupom -->
            <Border x:Name="BorderCupom" Background="White" Padding="25,20" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="8" Opacity="0.1"/>
                </Border.Effect>
                <StackPanel x:Name="PainelCupom">
                    <!-- Cabeçalho -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,15">
                        <Border Background="{StaticResource AmareloPrimarioBrush}" CornerRadius="6"
                                Width="44" Height="44" HorizontalAlignment="Center" Margin="0,0,0,8">
                            <TextBlock Text="IC" FontSize="18" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Imperial Colors" FontSize="16" FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Tintas e Revestimentos" FontSize="11"
                                   Foreground="{StaticResource CinzaTextoBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="CUPOM NÃO FISCAL" FontSize="11" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,5,0,0"
                                   Foreground="{StaticResource CinzaTextoBrush}"/>
                    </StackPanel>

                    <Border Height="1" Background="{StaticResource CinzaMedioBrush}" Margin="0,0,0,12"/>

                    <!-- Dados da venda -->
                    <Grid Margin="0,0,0,5">
                        <TextBlock Text="Venda Nº:" FontSize="12" Foreground="{StaticResource CinzaTextoBrush}"/>
                        <TextBlock x:Name="TxtNumeroVenda" HorizontalAlignment="Right" FontSize="12" FontWeight="SemiBold"/>
                    </Grid>
                    <Grid Margin="0,0,0,5">
                        <TextBlock Text="Data:" FontSize="12" Foreground="{StaticResource CinzaTextoBrush}"/>
                        <TextBlock x:Name="TxtData" HorizontalAlignment="Right" FontSize="12"/>
                    </Grid>
                    <Grid Margin="0,0,0,12">
                        <TextBlock Text="Cliente:" FontSize="12" Foreground="{StaticResource CinzaTextoBrush}"/>
                        <TextBlock x:Name="TxtCliente" HorizontalAlignment="Right" FontSize="12"/>
                    </Grid>

                    <Border Height="1" Background="{StaticResource CinzaMedioBrush}" Margin="0,0,0,12"/>

                    <!-- Cabeçalho dos itens -->
                    <Grid Margin="0,0,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Produto" FontSize="11" FontWeight="Bold" Foreground="{StaticResource CinzaTextoBrush}"/>
                        <TextBlock Grid.Column="1" Text="Qtd" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource CinzaTextoBrush}" HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="2" Text="Preço" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource CinzaTextoBrush}" HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="3" Text="Total" FontSize="11" FontWeight="Bold"
                                   Foreground="{StaticResource CinzaTextoBrush}" HorizontalAlignment="Right"/>
                    </Grid>
                    <Border Height="1" Background="{StaticResource CinzaMedioBrush}" Margin="0,0,0,8"/>

                    <!-- Itens -->
                    <ItemsControl x:Name="LstItens">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="90"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding NomeProduto}" FontSize="12" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Column="1" FontSize="12" HorizontalAlignment="Right">
                                        <Run Text="{Binding Quantidade}"/>
                                        <Run Text="{Binding Unidade}"/>
                                    </TextBlock>
                                    <TextBlock Grid.Column="2" FontSize="12" HorizontalAlignment="Right"
                                               Text="{Binding PrecoUnitario, Converter={StaticResource MoedaConverter}}"/>
                                    <TextBlock Grid.Column="3" FontSize="12" HorizontalAlignment="Right"
                                               Text="{Binding Subtotal, Converter={StaticResource MoedaConverter}}"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Height="1" Background="{StaticResource CinzaMedioBrush}" Margin="0,10,0,8"/>

                    <!-- Totais -->
                    <Grid Margin="0,0,0,5">
                        <TextBlock Text="Subtotal:" FontSize="12" Foreground="{StaticResource CinzaTextoBrush}"/>
                        <TextBlock x:Name="TxtSubtotal" HorizontalAlignment="Right" FontSize="12"/>
                    </Grid>
                    <Grid Margin="0,0,0,5">
                        <TextBlock Text="Desconto:" FontSize="12" Foreground="{StaticResource CinzaTextoBrush}"/>
                        <TextBlock x:Name="TxtDesconto" HorizontalAlignment="Right" FontSize="12"/>
                    </Grid>

                    <Border Height="2" Background="{StaticResource AmareloPrimarioBrush}" Margin="0,5,0,8"/>

                    <Grid>
                        <TextBlock Text="TOTAL:" FontSize="15" FontWeight="Bold"/>
                        <TextBlock x:Name="TxtTotal" HorizontalAlignment="Right" FontSize="18"
                                   FontWeight="Bold" Foreground="{StaticResource PretoPrimarioBrush}"/>
                    </Grid>

                    <Border Height="1" Background="{StaticResource CinzaMedioBrush}" Margin="0,12,0,12"/>

                    <TextBlock Text="Obrigado pela preferência!" HorizontalAlignment="Center"
                               FontSize="12" Foreground="{StaticResource CinzaTextoBrush}"
                               FontStyle="Italic"/>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Botões de ação -->
        <Border Grid.Row="1" Background="White" Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Style="{StaticResource BotaoSecundario}" Content="Imprimir"
                        Margin="0,0,10,0" Click="BtnImprimir_Click"/>
                <Button Style="{StaticResource BotaoPrimario}" Content="Salvar PDF"
                        Margin="0,0,10,0" Click="BtnSalvarPdf_Click"/>
                <Button Style="{StaticResource BotaoSecundario}" Content="Fechar"
                        Click="BtnFechar_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
