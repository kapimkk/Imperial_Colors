<UserControl x:Class="ImperialColors.UI.Views.EstoqueView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ImperialColors.UI.Converters">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/AppTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:MoedaConverter x:Key="MoedaConverter"/>
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
            <conv:InvertBoolToVisibilityConverter x:Key="InvertBoolToVisibility"/>
            <conv:InverseBoolConverter x:Key="InverseBool"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="30,25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <Grid Grid.Row="0">
            <StackPanel>
                <TextBlock Style="{StaticResource TituloModulo}" Text="Controle de Estoque"/>
                <TextBlock Foreground="{StaticResource CinzaTextoBrush}" FontSize="13" Margin="0,4,0,0">
                    <Run Text="{Binding TotalProdutos}"/>
                    <Run Text=" produtos cadastrados"/>
                </TextBlock>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Style="{StaticResource BotaoSecundario}" Command="{Binding MovimentacaoCommand}"
                        Margin="0,0,10,0" Content="↕  Movimentação"/>
                <Button Style="{StaticResource BotaoPrimario}" Command="{Binding NovoProdutoCommand}"
                        Content="+ Novo Produto"/>
            </StackPanel>
        </Grid>

        <!-- Barra de busca e filtros -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <Grid>
                        <TextBox x:Name="TxtBuscaEstoque" Style="{StaticResource TextBoxFiltro}"
                                 Text="{Binding TermoBusca, UpdateSourceTrigger=PropertyChanged}"
                                 KeyDown="TxtBuscaEstoque_KeyDown"/>
                        <TextBlock Text="🔍  Buscar por nome, código ou código de barras..."
                                   Foreground="{StaticResource CinzaTextoBrush}" FontSize="13"
                                   IsHitTestVisible="False" VerticalAlignment="Center" Margin="12,0,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TermoBusca}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <TextBlock x:Name="TxtAvisoBarrasEstoque" Margin="4,4,0,0" FontSize="12"
                               Foreground="{StaticResource VermelhoErroBrush}" Visibility="Collapsed"/>
                </StackPanel>
                <Button Grid.Column="1" Style="{StaticResource BotaoSecundario}" Margin="10,0,0,0"
                        Command="{Binding AtualizarCommand}" Content="⟳  Atualizar"/>
                <Button Grid.Column="2" Style="{StaticResource BotaoSecundario}" Margin="10,0,0,0"
                        Command="{Binding EditarProdutoCommand}" Content="✏  Editar"/>
                <Button Grid.Column="3" Style="{StaticResource BotaoPerigo}" Margin="10,0,0,0"
                        Command="{Binding ExcluirProdutoCommand}" Content="🗑  Excluir"/>
            </Grid>
        </Border>

        <!-- DataGrid de produtos -->
        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <DataGrid Style="{StaticResource DataGridModerno}"
                              ItemsSource="{Binding Produtos}"
                              SelectedItem="{Binding ProdutoSelecionado}"
                              ColumnHeaderStyle="{StaticResource DataGridHeaderModerno}"
                              IsEnabled="{Binding Carregando, Converter={StaticResource InverseBool}}"
                              MouseDoubleClick="DataGrid_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Código" Binding="{Binding CodigoInterno}" Width="100"/>
                    <DataGridTextColumn Header="Cód. Barras" Binding="{Binding CodigoBarras}" Width="120"/>
                    <DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="*"/>
                    <DataGridTextColumn Header="Categoria" Binding="{Binding CategoriaNome}" Width="120"/>
                    <DataGridTextColumn Header="Marca" Binding="{Binding MarcaNome}" Width="100"/>
                    <DataGridTextColumn Header="Estoque" Width="130">
                        <DataGridTextColumn.Binding>
                            <MultiBinding Converter="{StaticResource QuantidadeUnidadeConverter}">
                                <Binding Path="QuantidadeEstoque"/>
                                <Binding Path="Unidade"/>
                            </MultiBinding>
                        </DataGridTextColumn.Binding>
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SemEstoque}" Value="True">
                                        <Setter Property="Foreground" Value="#DC3545"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding EstoqueBaixo}" Value="True">
                                        <Setter Property="Foreground" Value="#FD7E14"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Custo"
                                        Binding="{Binding Custo, Converter={StaticResource MoedaConverter}}"
                                        Width="100"/>
                    <DataGridTextColumn Header="Preço Venda"
                                        Binding="{Binding PrecoVenda, Converter={StaticResource MoedaConverter}}"
                                        Width="120"/>
                    <DataGridTemplateColumn Header="Status" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border HorizontalAlignment="Center" CornerRadius="4" Padding="8,3">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#D4EDDA"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SemEstoque}" Value="True">
                                                    <Setter Property="Background" Value="#F8D7DA"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding EstoqueBaixo}" Value="True">
                                                    <Setter Property="Background" Value="#FFF3CD"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="OK"/>
                                                <Setter Property="Foreground" Value="#155724"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding SemEstoque}" Value="True">
                                                        <Setter Property="Text" Value="Sem Estoque"/>
                                                        <Setter Property="Foreground" Value="#721C24"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding EstoqueBaixo}" Value="True">
                                                        <Setter Property="Text" Value="Baixo"/>
                                                        <Setter Property="Foreground" Value="#856404"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
                    </DataGrid>

                    <Border Background="#80FFFFFF" Visibility="{Binding Carregando, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Carregando..." FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource PretoPrimarioBrush}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="1" Style="{StaticResource Card}" Padding="12,8" Margin="0,10,0,0">
                <Grid>
                    <TextBlock VerticalAlignment="Center" Foreground="{StaticResource CinzaTextoBrush}"
                               Text="{Binding InfoPaginacao}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource BotaoSecundario}" Content="◀ Anterior"
                                Command="{Binding PaginaAnteriorCommand}" Margin="0,0,8,0"/>
                        <Button Style="{StaticResource BotaoSecundario}" Content="Próxima ▶"
                                Command="{Binding PaginaProximaCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
