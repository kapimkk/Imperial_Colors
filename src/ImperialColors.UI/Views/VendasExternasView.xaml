<UserControl x:Class="ImperialColors.UI.Views.VendasExternasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ImperialColors.UI.Converters">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/AppTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:MoedaConverter x:Key="MoedaConverter"/>
            <conv:DataHoraConverter x:Key="DataHoraConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="30,25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <StackPanel>
                <TextBlock Style="{StaticResource TituloModulo}" Text="Vendas Externas"/>
                <TextBlock Text="Consolide vendas realizadas fora do estabelecimento físico"
                           FontSize="12" Foreground="{StaticResource CinzaTextoBrush}" Margin="0,4,0,0"/>
            </StackPanel>
            <Button Style="{StaticResource BotaoPrimario}" HorizontalAlignment="Right" VerticalAlignment="Center"
                    Command="{Binding RegistrarVendaCommand}" Content="+ Registrar Venda Externa"/>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <DataGrid Style="{StaticResource DataGridModerno}"
                      ColumnHeaderStyle="{StaticResource DataGridHeaderModerno}"
                      ItemsSource="{Binding Vendas}" SelectedItem="{Binding VendaSelecionada}"
                      AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nº Venda" Binding="{Binding NumeroVendaExterna}" Width="160"/>
                    <DataGridTextColumn Header="Data" Binding="{Binding DataVenda, Converter={StaticResource DataHoraConverter}}" Width="150"/>
                    <DataGridTextColumn Header="Itens" Binding="{Binding TotalItens}" Width="70"/>
                    <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, Converter={StaticResource MoedaConverter}}" Width="110"/>
                    <DataGridTextColumn Header="Total" Binding="{Binding Total, Converter={StaticResource MoedaConverter}}" Width="110"/>
                    <DataGridTextColumn Header="Usuário" Binding="{Binding Usuario}" Width="*"/>
                    <DataGridTextColumn Header="Observações" Binding="{Binding Observacoes}" Width="180"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
