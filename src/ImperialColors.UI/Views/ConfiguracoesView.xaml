<UserControl x:Class="ImperialColors.UI.Views.ConfiguracoesView"

             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             xmlns:helpers="clr-namespace:ImperialColors.UI.Helpers">



    <UserControl.Resources>

        <ResourceDictionary Source="/Resources/AppTheme.xaml"/>

    </UserControl.Resources>



    <ScrollViewer Style="{StaticResource ScrollViewerComMargem}"
                  VerticalScrollBarVisibility="Auto"
                  helpers:ScrollViewerMouseWheelHelper.Habilitar="True">

        <Grid Margin="22,20">

            <Grid.RowDefinitions>

                <RowDefinition Height="Auto"/>

                <RowDefinition Height="16"/>

                <RowDefinition Height="Auto"/>

                <RowDefinition Height="20"/>

                <RowDefinition Height="Auto"/>

            </Grid.RowDefinitions>



            <StackPanel Grid.Row="0">

                <TextBlock Style="{StaticResource TituloModulo}" Text="Configurações"/>

                <TextBlock x:Name="TxtInfoEnv" TextWrapping="Wrap" Margin="0,8,0,0"

                           Foreground="{StaticResource CinzaTextoBrush}" FontSize="12"/>

            </StackPanel>



            <!-- Cards de submódulos -->

            <UniformGrid Grid.Row="2" Columns="3" x:Name="GridSubmodulos">

                <Button x:Name="BtnCardGeral" Style="{StaticResource SubmoduloCard}"

                        Click="BtnCardGeral_Click">

                    <Grid>

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="Auto"/>

                            <ColumnDefinition Width="*"/>

                        </Grid.ColumnDefinitions>

                        <TextBlock Text="⚙" FontSize="26" VerticalAlignment="Center" Margin="0,0,14,0"/>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">

                            <TextBlock Text="Geral" FontSize="14" FontWeight="Bold"

                                       Foreground="{StaticResource PretoPrimarioBrush}"/>

                            <TextBlock Text="Banco de dados, empresa e informações do sistema"

                                       FontSize="11" Foreground="{StaticResource CinzaTextoBrush}"

                                       TextWrapping="Wrap" Margin="0,4,0,0"/>

                        </StackPanel>

                    </Grid>

                </Button>



                <Button x:Name="BtnCardPerifericos" Style="{StaticResource SubmoduloCard}"

                        Click="BtnCardPerifericos_Click">

                    <Grid>

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="Auto"/>

                            <ColumnDefinition Width="*"/>

                        </Grid.ColumnDefinitions>

                        <TextBlock Text="🖨" FontSize="26" VerticalAlignment="Center" Margin="0,0,14,0"/>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">

                            <TextBlock Text="Periféricos" FontSize="14" FontWeight="Bold"

                                       Foreground="{StaticResource PretoPrimarioBrush}"/>

                            <TextBlock Text="Impressoras e leitor de código de barras — configure e teste"

                                       FontSize="11" Foreground="{StaticResource CinzaTextoBrush}"

                                       TextWrapping="Wrap" Margin="0,4,0,0"/>

                        </StackPanel>

                    </Grid>

                </Button>



                <Button x:Name="BtnCardUsuarios" Style="{StaticResource SubmoduloCard}"

                        Visibility="Collapsed" Click="BtnCardUsuarios_Click">

                    <Grid>

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="Auto"/>

                            <ColumnDefinition Width="*"/>

                        </Grid.ColumnDefinitions>

                        <TextBlock Text="👥" FontSize="26" VerticalAlignment="Center" Margin="0,0,14,0"/>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">

                            <TextBlock Text="Gestão de Usuários" FontSize="14" FontWeight="Bold"

                                       Foreground="{StaticResource PretoPrimarioBrush}"/>

                            <TextBlock Text="Aprovar cadastros, permissões e contas de acesso"

                                       FontSize="11" Foreground="{StaticResource CinzaTextoBrush}"

                                       TextWrapping="Wrap" Margin="0,4,0,0"/>

                        </StackPanel>

                    </Grid>

                </Button>

            </UniformGrid>



            <!-- Conteúdo do submódulo -->

            <Border Grid.Row="4" Style="{StaticResource Card}" Padding="0">

                <Grid>

                    <StackPanel x:Name="PainelGeral" Margin="20" Visibility="Visible">

                        <Border Padding="0,0,0,16" Margin="0,0,0,16"

                                BorderBrush="{StaticResource CinzaMedioBrush}" BorderThickness="0,0,0,1">

                            <StackPanel>

                                <TextBlock Text="Banco de Dados (.env)" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,15"/>

                                <TextBlock Style="{StaticResource LabelCampo}" Text="String de Conexão (senha mascarada)"/>

                                <TextBox x:Name="TxtConnectionString" Style="{StaticResource TextBoxMultilinha}"

                                         IsReadOnly="True" Margin="0,0,0,12"/>

                                <StackPanel Orientation="Horizontal">

                                    <Button Style="{StaticResource BotaoPrimario}" Content="Testar Conexão"

                                            Click="BtnTestarConexao_Click" Margin="0,0,10,0"/>

                                    <Button Style="{StaticResource BotaoSecundario}" Content="Abrir .env"

                                            Click="BtnAbrirEnv_Click"/>

                                </StackPanel>

                                <Border x:Name="StatusConexao" Margin="0,10,0,0" Padding="10" CornerRadius="6"

                                        Visibility="Collapsed">

                                    <TextBlock x:Name="TxtStatusConexao" FontSize="12"/>

                                </Border>

                            </StackPanel>

                        </Border>



                        <Border Padding="0,0,0,16" Margin="0,0,0,16"

                                BorderBrush="{StaticResource CinzaMedioBrush}" BorderThickness="0,0,0,1">

                            <StackPanel>

                                <TextBlock Text="Empresa (.env)" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,15"/>

                                <Grid>

                                    <Grid.ColumnDefinitions>

                                        <ColumnDefinition Width="*"/>

                                        <ColumnDefinition Width="*"/>

                                    </Grid.ColumnDefinitions>

                                    <Grid.RowDefinitions>

                                        <RowDefinition Height="Auto"/>

                                        <RowDefinition Height="Auto"/>

                                        <RowDefinition Height="Auto"/>

                                        <RowDefinition Height="Auto"/>

                                        <RowDefinition Height="Auto"/>

                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,10">

                                        <TextBlock Style="{StaticResource LabelCampo}" Text="Nome Fantasia"/>

                                        <TextBox x:Name="TxtEmpresaNome" Style="{StaticResource TextBoxModerno}" IsReadOnly="True"/>

                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,10">

                                        <TextBlock Style="{StaticResource LabelCampo}" Text="Razão Social"/>

                                        <TextBox x:Name="TxtEmpresaRazaoSocial" Style="{StaticResource TextBoxModerno}" IsReadOnly="True"/>

                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,10">

                                        <TextBlock Style="{StaticResource LabelCampo}" Text="CNPJ"/>

                                        <TextBox x:Name="TxtEmpresaCnpj" Style="{StaticResource TextBoxModerno}" IsReadOnly="True"/>

                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,10">

                                        <TextBlock Style="{StaticResource LabelCampo}" Text="Subtítulo"/>

                                        <TextBox x:Name="TxtEmpresaSubtitulo" Style="{StaticResource TextBoxModerno}" IsReadOnly="True"/>

                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,10">

                                        <TextBlock Style="{StaticResource LabelCampo}" Text="Inscrição Estadual (IE)"/>

                                        <TextBox x:Name="TxtEmpresaIe" Style="{StaticResource TextBoxModerno}" IsReadOnly="True"/>

                                    </StackPanel>

                                    <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,10,10">

                                        <TextBlock Style="{StaticResource LabelCampo}" Text="Telefone"/>

                                        <TextBox x:Name="TxtEmpresaTelefone" Style="{StaticResource TextBoxModerno}" IsReadOnly="True"/>

                                    </StackPanel>

                                    <StackPanel Grid.Row="3" Grid.Column="1" Margin="10,0,0,10">

                                        <TextBlock Style="{StaticResource LabelCampo}" Text="E-mail"/>

                                        <TextBox x:Name="TxtEmpresaEmail" Style="{StaticResource TextBoxModerno}" IsReadOnly="True"/>

                                    </StackPanel>

                                    <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2">

                                        <TextBlock Style="{StaticResource LabelCampo}" Text="Endereço"/>

                                        <TextBox x:Name="TxtEmpresaEndereco" Style="{StaticResource TextBoxModerno}" IsReadOnly="True"/>

                                    </StackPanel>

                                </Grid>

                            </StackPanel>

                        </Border>



                        <StackPanel>

                            <TextBlock Text="Sobre o Sistema" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>

                            <TextBlock x:Name="TxtSobreEmpresa" FontSize="14" FontWeight="Bold"/>

                            <TextBlock Text="Versão 1.2.0 | Pagamentos PDV e Periféricos" FontSize="12"

                                       Foreground="{StaticResource CinzaTextoBrush}" Margin="0,4,0,0"/>

                            <TextBlock Text=".NET 10 | WPF | PostgreSQL | Entity Framework Core"

                                       FontSize="11" Foreground="{StaticResource CinzaTextoBrush}"/>

                        </StackPanel>

                    </StackPanel>



                    <ContentControl x:Name="PainelPerifericos" Margin="20" Visibility="Collapsed"/>

                    <ContentControl x:Name="PainelGestaoUsuarios" Margin="20" Visibility="Collapsed"/>

                </Grid>

            </Border>

        </Grid>

    </ScrollViewer>

</UserControl>


