<UserControl x:Class="ImperialColors.UI.Views.ConfiguracoesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <ResourceDictionary Source="/Resources/AppTheme.xaml"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="30,25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Style="{StaticResource TituloModulo}" Text="Configurações"/>
            </StackPanel>

            <!-- Conexão banco -->
            <Border Grid.Row="2" Style="{StaticResource Card}" Padding="20">
                <StackPanel>
                    <TextBlock Text="Banco de Dados" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,15"/>
                    <StackPanel Margin="0,0,0,12">
                        <TextBlock Style="{StaticResource LabelCampo}" Text="String de Conexão"/>
                        <TextBox x:Name="TxtConnectionString" Style="{StaticResource TextBoxModerno}"
                                 Height="60" TextWrapping="Wrap" AcceptsReturn="False"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource BotaoPrimario}" Content="Testar Conexão"
                                Click="BtnTestarConexao_Click" Margin="0,0,10,0"/>
                        <Button Style="{StaticResource BotaoSucesso}" Content="Salvar"
                                Click="BtnSalvarConexao_Click"/>
                    </StackPanel>
                    <Border x:Name="StatusConexao" Margin="0,10,0,0" Padding="10" CornerRadius="6"
                            Visibility="Collapsed">
                        <TextBlock x:Name="TxtStatusConexao" FontSize="12"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Sobre -->
            <Border Grid.Row="4" Style="{StaticResource Card}" Padding="20">
                <StackPanel>
                    <TextBlock Text="Sobre o Sistema" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Background="{StaticResource AmareloPrimarioBrush}" CornerRadius="8"
                                Width="55" Height="55" Margin="0,0,20,0">
                            <TextBlock Text="IC" FontSize="20" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Imperial Colors - Sistema de Gestão" FontSize="14" FontWeight="Bold"/>
                            <TextBlock Text="Versão 1.0.0" FontSize="12" Foreground="{StaticResource CinzaTextoBrush}"/>
                            <TextBlock Text=".NET 10 | WPF | PostgreSQL | Entity Framework Core"
                                       FontSize="11" Foreground="{StaticResource CinzaTextoBrush}"/>
                            <TextBlock Text="Desenvolvido com Clean Architecture e padrões SOLID"
                                       FontSize="11" Foreground="{StaticResource CinzaTextoBrush}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
