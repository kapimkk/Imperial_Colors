<UserControl x:Class="ImperialColors.UI.Views.VendasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ImperialColors.UI.Converters">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/AppTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:MoedaConverter x:Key="MoedaConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="30,25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <StackPanel>
                <TextBlock Style="{StaticResource TituloModulo}" Text="Histórico de Vendas"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Style="{StaticResource BotaoSecundario}" Command="{Binding ImprimirCupomCommand}"
                        Margin="0,0,10,0" Content="🧾  Cupom"/>
                <Button Style="{StaticResource BotaoPerigo}" Command="{Binding CancelarVendaCommand}"
                        Margin="0,0,10,0" Content="✕  Cancelar Venda"/>
                <Button Style="{StaticResource BotaoPrimario}" Command="{Binding NovaVendaCommand}"
                        Content="+ Nova Venda (PDV)"/>
            </StackPanel>
        </Grid>

        <!-- Filtros -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="De:" VerticalAlignment="Center" Margin="0,0,8,0"
                           Style="{StaticResource LabelCampo}"/>
                <DatePicker x:Name="DpInicio" SelectedDate="{Binding DataInicio}" Width="140" Margin="0,0,15,0"
                            SelectedDateFormat="Short"/>
                <TextBlock Text="Até:" VerticalAlignment="Center" Margin="0,0,8,0"
                           Style="{StaticResource LabelCampo}"/>
                <DatePicker x:Name="DpFim" SelectedDate="{Binding DataFim}" Width="140" Margin="0,0,15,0"/>
                <Button Style="{StaticResource BotaoPrimario}" Command="{Binding FiltrarCommand}"
                        Content="🔍  Filtrar" Padding="15,8"/>
            </StackPanel>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="4" Style="{StaticResource Card}" Padding="0">
            <DataGrid Style="{StaticResource DataGridModerno}" ColumnHeaderStyle="{StaticResource DataGridHeaderModerno}"
                      ItemsSource="{Binding Vendas}" SelectedItem="{Binding VendaSelecionada}"
                      MouseDoubleClick="DataGrid_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nº Venda" Binding="{Binding NumeroVenda}" Width="130"/>
                    <DataGridTextColumn Header="Data" Binding="{Binding DataVenda, StringFormat={}{0:dd/MM/yyyy HH:mm}}" Width="140"/>
                    <DataGridTextColumn Header="Cliente" Binding="{Binding ClienteNome}" Width="*"/>
                    <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, Converter={StaticResource MoedaConverter}}" Width="100"/>
                    <DataGridTextColumn Header="Desconto" Binding="{Binding Desconto, Converter={StaticResource MoedaConverter}}" Width="100"/>
                    <DataGridTextColumn Header="Total" Binding="{Binding Total, Converter={StaticResource MoedaConverter}}" Width="110"/>
                    <DataGridTemplateColumn Header="Status" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border HorizontalAlignment="Center" Padding="8,3" CornerRadius="4">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#D4EDDA"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding StatusDescricao}" Value="Cancelada">
                                                    <Setter Property="Background" Value="#F8D7DA"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding StatusDescricao}" Value="Aberta">
                                                    <Setter Property="Background" Value="#FFF3CD"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding StatusDescricao}" FontSize="11" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#155724"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StatusDescricao}" Value="Cancelada">
                                                        <Setter Property="Foreground" Value="#721C24"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding StatusDescricao}" Value="Aberta">
                                                        <Setter Property="Foreground" Value="#856404"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
