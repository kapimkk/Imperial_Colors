<Window x:Class="ImperialColors.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:ImperialColors.UI.Helpers"
        Title="Imperial Colors - Tintas e Revestimentos"
        Width="1280" Height="780"
        MinWidth="1024" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#1A1A2E"
        x:Name="JanelaPrincipal">

    <Border ClipToBounds="True" Background="White">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Menu Lateral -->
            <Border Grid.Column="0" Background="{StaticResource MenuLateralBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Logo e título -->
                    <Border Grid.Row="0" Padding="20,25,20,20" BorderBrush="#2D2D4E" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <Image x:Name="ImgLogoMenu" Width="44" Height="44" HorizontalAlignment="Left"
                                   Stretch="Uniform" Margin="0,0,0,10"/>
                            <TextBlock x:Name="TxtEmpresaNome" Foreground="White"
                                       FontSize="15" FontWeight="Bold" Margin="0,0,0,2"/>
                            <TextBlock x:Name="TxtEmpresaSubtitulo" Foreground="#8B8BAD"
                                       FontSize="11"/>
                        </StackPanel>
                    </Border>

                    <!-- Navegação -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  Style="{StaticResource ScrollViewerComMargem}" Margin="0"
                                  helpers:ScrollViewerMouseWheelHelper.Habilitar="True">
                        <StackPanel Margin="10,15,10,0">
                            <TextBlock Text="MENU PRINCIPAL" Foreground="#6B6B8A" FontSize="10"
                                       FontWeight="Bold" Margin="10,0,0,8"/>

                            <Button x:Name="BtnDashboard" Style="{StaticResource MenuButton}"
                                    Click="BtnDashboard_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x2302;" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="BtnEstoque" Style="{StaticResource MenuButton}"
                                    Click="BtnEstoque_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x2610;" FontSize="16" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Estoque" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="BtnVendas" Style="{StaticResource MenuButton}"
                                    Click="BtnVendas_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4B0;" FontSize="14" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Vendas" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="BtnPDV" Style="{StaticResource MenuButtonDestaque}"
                                    Click="BtnPDV_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F6D2;" FontSize="14" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="PDV - Venda (F2)" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="BtnClientes" Style="{StaticResource MenuButton}"
                                    Click="BtnClientes_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F464;" FontSize="14" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Clientes" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="BtnMercadorias" Style="{StaticResource MenuButton}"
                                    Click="BtnMercadorias_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4E6;" FontSize="14" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Fornecedores/Compra" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="BtnRelatorios" Style="{StaticResource MenuButton}"
                                    Click="BtnRelatorios_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4CA;" FontSize="14" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Relatórios" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="BtnConfiguracoes" Style="{StaticResource MenuButton}"
                                    Click="BtnConfiguracoes_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x2699;" FontSize="14" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Configurações" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Rodapé do menu -->
                    <Border Grid.Row="2" Padding="15,15" BorderBrush="#2D2D4E" BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Usuário" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock x:Name="TxtUsuarioLogado" Foreground="#8B8BAD" FontSize="11"/>
                                <TextBlock x:Name="TxtPermissaoLogada" Foreground="#6B6B8A" FontSize="10"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="⎋" Background="Transparent" BorderThickness="0"
                                        Foreground="#8B8BAD" FontSize="14" Cursor="Hand"
                                        Click="BtnLogout_Click" ToolTip="Sair" Margin="0,0,8,0"/>
                                <Button Content="✕" Background="Transparent" BorderThickness="0"
                                        Foreground="#8B8BAD" FontSize="16" Cursor="Hand"
                                        Click="BtnFechar_Click" ToolTip="Fechar"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Área de conteúdo principal -->
            <Grid Grid.Column="1" Background="{StaticResource CinzaClaroBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Barra de título (arrastar) -->
                <Border Grid.Row="0" Background="White" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid Margin="20,0">
                        <TextBlock x:Name="TxtTituloPagina" Text="Dashboard"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource PretoPrimarioBrush}"
                                   VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock x:Name="TxtHora" FontSize="12" Foreground="{StaticResource CinzaTextoBrush}"
                                       VerticalAlignment="Center" Margin="0,0,15,0"/>
                            <Button Content="—" Background="Transparent" BorderThickness="0"
                                    Foreground="{StaticResource CinzaTextoBrush}" FontSize="16" Cursor="Hand"
                                    Click="BtnMinimizar_Click" ToolTip="Minimizar"/>
                            <Button Content="☐" Background="Transparent" BorderThickness="0"
                                    Foreground="{StaticResource CinzaTextoBrush}" FontSize="14" Cursor="Hand"
                                    Click="BtnMaximizar_Click" ToolTip="Maximizar"/>
                            <Button Content="✕" Background="Transparent" BorderThickness="0"
                                    Foreground="{StaticResource CinzaTextoBrush}" FontSize="16" Cursor="Hand"
                                    Click="BtnFechar_Click" ToolTip="Fechar"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Frame de conteúdo -->
                <ContentControl x:Name="ConteudoPrincipal" Grid.Row="1" Margin="0"/>
            </Grid>
        </Grid>
    </Border>
</Window>
