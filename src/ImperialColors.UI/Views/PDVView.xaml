<Window x:Class="ImperialColors.UI.Views.PDVView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:ImperialColors.UI.Converters"
        Title="PDV - Ponto de Venda" Width="1150" Height="780"
        MinWidth="1000" MinHeight="680"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/AppTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:MoedaConverter x:Key="MoedaConverter"/>
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
            <conv:QuantidadeUnidadeConverter x:Key="QuantidadeUnidadeConverter"/>

            <Style x:Key="EtapaPdvTab" TargetType="RadioButton">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="8"
                                    Padding="18,10" Cursor="Hand" Margin="0,0,8,0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource AmareloPrimarioBrush}"/>
                                    <Setter Property="Foreground" Value="{StaticResource PretoPrimarioBrush}"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="False">
                                    <Setter TargetName="Bd" Property="Background" Value="{StaticResource CinzaClaroBrush}"/>
                                    <Setter Property="Foreground" Value="{StaticResource CinzaTextoBrush}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.92"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Background" Value="Transparent"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{StaticResource CinzaClaroBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <Border Grid.Row="0" Background="White" Padding="20,16" BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel>
                    <TextBlock Text="PDV - Nova Venda" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource PretoPrimarioBrush}"/>
                    <TextBlock x:Name="TxtNumeroVenda" FontSize="12"
                               Foreground="{StaticResource CinzaTextoBrush}" Margin="0,3,0,0"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" Style="{StaticResource BotaoPerigo}"
                        Click="BtnFechar_Click" Content="✕  Cancelar Venda"/>
            </Grid>
        </Border>

        <!-- Abas de etapas -->
        <Border Grid.Row="1" Background="White" Padding="20,12" BorderBrush="#E8E8E8" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="RbEtapaProdutos" Style="{StaticResource EtapaPdvTab}"
                             GroupName="EtapaPdv" Content="1. Produtos"
                             Checked="EtapaPdv_Checked"/>
                <RadioButton x:Name="RbEtapaCliente" Style="{StaticResource EtapaPdvTab}"
                             GroupName="EtapaPdv" Content="2. Cliente"
                             Checked="EtapaPdv_Checked"/>
                <RadioButton x:Name="RbEtapaPagamento" Style="{StaticResource EtapaPdvTab}"
                             GroupName="EtapaPdv" Content="3. Pagamento"
                             Checked="EtapaPdv_Checked"/>
                <TextBlock x:Name="TxtResumoEtapa" VerticalAlignment="Center" Margin="12,0,0,0"
                           FontSize="12" Foreground="{StaticResource CinzaTextoBrush}"/>
            </StackPanel>
        </Border>

        <!-- Conteúdo principal -->
        <Grid Grid.Row="2" Margin="20,16,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Área das etapas -->
            <Grid Grid.Column="0" Margin="0,0,12,0">

                <!-- ETAPA 1: PRODUTOS -->
                <Grid x:Name="PainelEtapaProdutos">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource Card}" Padding="15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource LabelCampo}"
                                           Text="Buscar produto (nome, código ou código de barras)"/>
                                <TextBox x:Name="TxtBuscaProduto" Style="{StaticResource TextBoxModerno}"
                                         KeyDown="TxtBuscaProduto_KeyDown"
                                         TextChanged="TxtBuscaProduto_TextChanged"/>
                                <TextBlock x:Name="TxtAvisoBarras" Margin="0,4,0,0" FontSize="12"
                                           Foreground="{StaticResource VermelhoErroBrush}" Visibility="Collapsed"/>
                            </StackPanel>
                            <Button Grid.Column="2" Style="{StaticResource BotaoPrimario}" Content="Adicionar"
                                    Click="BtnAdicionarProduto_Click" VerticalAlignment="Bottom"/>
                        </Grid>
                    </Border>

                    <Popup x:Name="PopupResultados"
                           PlacementTarget="{Binding ElementName=TxtBuscaProduto}"
                           Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                        <Border Background="White" CornerRadius="8"
                                BorderBrush="{StaticResource CinzaMedioBrush}" BorderThickness="1"
                                MinWidth="{Binding ActualWidth, ElementName=TxtBuscaProduto}"
                                MaxHeight="220" Margin="0,4,0,0">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.15"/>
                            </Border.Effect>
                            <ListBox x:Name="LstResultados" BorderThickness="0"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     ScrollViewer.CanContentScroll="True"
                                     MouseDoubleClick="LstResultados_MouseDoubleClick">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="8,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock FontSize="13" FontWeight="SemiBold" Text="{Binding Nome}"/>
                                                <TextBlock FontSize="11" Foreground="{StaticResource CinzaTextoBrush}">
                                                    <Run Text="{Binding CodigoInterno}"/>
                                                    <Run Text=" | Estoque: "/>
                                                    <Run>
                                                        <Run.Text>
                                                            <MultiBinding Converter="{StaticResource QuantidadeUnidadeConverter}">
                                                                <Binding Path="QuantidadeEstoque"/>
                                                                <Binding Path="Unidade"/>
                                                            </MultiBinding>
                                                        </Run.Text>
                                                    </Run>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" FontSize="15" FontWeight="Bold"
                                                       Foreground="{StaticResource AmareloPrimarioBrush}" VerticalAlignment="Center"
                                                       Text="{Binding PrecoVenda, Converter={StaticResource MoedaConverter}}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Popup>

                    <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Padding="15,12" Background="{StaticResource CinzaClaroBrush}" CornerRadius="10,10,0,0">
                                <Grid>
                                    <TextBlock Text="Itens da Venda" FontSize="14" FontWeight="SemiBold"/>
                                    <Button HorizontalAlignment="Right" Style="{StaticResource BotaoPerigo}"
                                            Content="Limpar" Click="BtnLimpar_Click" Padding="12,5"/>
                                </Grid>
                            </Border>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                          Style="{StaticResource ScrollViewerComMargem}">
                                <DataGrid x:Name="DgItens" Style="{StaticResource DataGridModerno}"
                                          ColumnHeaderStyle="{StaticResource DataGridHeaderModerno}"
                                          ItemsSource="{Binding ItensVenda}" MinHeight="180">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Produto" Binding="{Binding NomeProduto}" Width="*"/>
                                        <DataGridTextColumn Header="Cód" Binding="{Binding CodigoInterno}" Width="70"/>
                                        <DataGridTemplateColumn Header="Qtd" Width="90">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="22"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="22"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Button Content="-" Background="{StaticResource CinzaMedioBrush}"
                                                                BorderThickness="0" Tag="{Binding}" Click="BtnDiminuirQtd_Click"/>
                                                        <TextBox Grid.Column="1" Text="{Binding Quantidade, UpdateSourceTrigger=PropertyChanged}"
                                                                 TextAlignment="Center" BorderThickness="0" LostFocus="TxtQtdItem_LostFocus" Tag="{Binding}"/>
                                                        <Button Grid.Column="2" Content="+" Background="{StaticResource CinzaMedioBrush}"
                                                                BorderThickness="0" Tag="{Binding}" Click="BtnAumentarQtd_Click"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Preço Un." Width="100"
                                            Binding="{Binding PrecoUnitario, Converter={StaticResource MoedaConverter}}"/>
                                        <DataGridTextColumn Header="Subtotal" Width="100"
                                                            Binding="{Binding Subtotal, Converter={StaticResource MoedaConverter}}"/>
                                        <DataGridTemplateColumn Header="" Width="36">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Button Content="✕" Background="Transparent" BorderThickness="0"
                                                            Foreground="{StaticResource VermelhoErroBrush}" Tag="{Binding}"
                                                            Click="BtnRemoverItem_Click"/>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ETAPA 2: CLIENTE -->
                <ScrollViewer x:Name="PainelEtapaCliente" Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto" Style="{StaticResource ScrollViewerComMargem}">
                    <StackPanel>
                        <TextBlock Text="Identificação do Cliente" FontSize="16" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="Informe quem está comprando. Padrão: Consumidor Final."
                                   FontSize="12" Foreground="{StaticResource CinzaTextoBrush}" Margin="0,0,0,16"/>

                        <Border Style="{StaticResource Card}" Padding="18">
                            <StackPanel>
                                <RadioButton x:Name="RbConsumidorFinal" GroupName="ModoCliente"
                                             Content="Consumidor Final" FontWeight="SemiBold"
                                             Margin="0,0,0,14" Checked="ModoCliente_Changed"/>

                                <RadioButton x:Name="RbClienteCadastrado" GroupName="ModoCliente"
                                             Content="Cliente cadastrado" FontWeight="SemiBold"
                                             Margin="0,0,0,8" Checked="ModoCliente_Changed"/>
                                <Border x:Name="PainelClienteCadastrado" Padding="12,0,0,14" Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource LabelCampo}" Text="Buscar por Nome, CPF ou CNPJ"/>
                                        <TextBox x:Name="TxtBuscaCliente" Style="{StaticResource TextBoxModerno}"
                                                 TextChanged="TxtBuscaCliente_TextChanged" Margin="0,0,0,10"/>
                                        <ListBox x:Name="LstClientes" MaxHeight="200"
                                                 SelectionChanged="LstClientes_SelectionChanged">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="0,4">
                                                        <TextBlock Text="{Binding Nome}" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding DocumentoExibicao}" FontSize="11"
                                                                   Foreground="{StaticResource CinzaTextoBrush}"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>
                                </Border>

                                <RadioButton x:Name="RbDadosCupom" GroupName="ModoCliente"
                                             Content="Informar dados no cupom (sem cadastro)" FontWeight="SemiBold"
                                             Margin="0,0,0,8" Checked="ModoCliente_Changed"/>
                                <Border x:Name="PainelDadosCupom" Padding="12,0,0,0" Visibility="Collapsed">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                            <RadioButton x:Name="RbPessoaFisica" GroupName="TipoPessoa" Content="PF"
                                                         IsChecked="True" Margin="0,0,16,0"/>
                                            <RadioButton x:Name="RbPessoaJuridica" GroupName="TipoPessoa" Content="PJ"
                                                         Checked="TipoPessoaCupom_Changed" Unchecked="TipoPessoaCupom_Changed"/>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock x:Name="LblNomeCupom" Style="{StaticResource LabelCampo}" Text="Nome *"/>
                                            <TextBox x:Name="TxtNomeCupom" Style="{StaticResource TextBoxModerno}"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock x:Name="LblDocumentoCupom" Style="{StaticResource LabelCampo}" Text="CPF"/>
                                            <TextBox x:Name="TxtDocumentoCupom" Style="{StaticResource TextBoxModerno}"
                                                     MaxLength="18" TextChanged="TxtDocumentoCupom_TextChanged"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <TextBlock x:Name="TxtResumoCliente" Margin="0,12,0,0" FontSize="12"
                                   Foreground="{StaticResource VerdeSucessoBrush}" FontWeight="SemiBold"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- ETAPA 3: PAGAMENTO -->
                <ScrollViewer x:Name="PainelEtapaPagamento" Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto" Style="{StaticResource ScrollViewerComMargem}">
                    <StackPanel>
                        <TextBlock Text="Composição de Pagamentos" FontSize="16" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="Adicione uma ou mais formas até cobrir o total da venda."
                                   FontSize="12" Foreground="{StaticResource CinzaTextoBrush}" Margin="0,0,0,14"/>

                        <Border Background="{StaticResource PretoPrimarioBrush}" CornerRadius="10" Padding="16" Margin="0,0,0,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="TOTAL DA VENDA" FontSize="10" Foreground="#CCFFFFFF" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TxtPagamentoTotal" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="TOTAL PAGO" FontSize="10" Foreground="#CCFFFFFF" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TxtTotalPago" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="SALDO RESTANTE" FontSize="10" Foreground="#CCFFFFFF" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TxtSaldoRestante" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource Card}" Padding="0" Margin="0,0,0,12">
                            <DataGrid x:Name="DgPagamentos" AutoGenerateColumns="False" CanUserAddRows="False"
                                      HeadersVisibility="Column" IsReadOnly="True" BorderThickness="0"
                                      MinHeight="100" MaxHeight="180">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Forma" Binding="{Binding Descricao}" Width="*"/>
                                    <DataGridTextColumn Header="Valor" Binding="{Binding ValorFormatado}" Width="100"/>
                                    <DataGridTextColumn Header="Troco" Binding="{Binding TrocoFormatado}" Width="80"/>
                                    <DataGridTemplateColumn Header="" Width="40">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="✕" Style="{StaticResource BotaoPerigo}" Padding="4,2"
                                                        Click="BtnRemoverPagamento_Click" Tag="{Binding}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <Border Style="{StaticResource Card}" Padding="14">
                            <StackPanel>
                                <TextBlock Style="{StaticResource LabelCampo}" Text="Adicionar forma de pagamento" Margin="0,0,0,10"/>
                                <UniformGrid x:Name="GridFormasPagamento" Columns="3" Margin="0,0,0,12">
                                    <ToggleButton x:Name="BtnDinheiro" Tag="Dinheiro" Style="{StaticResource TogglePagamento}"
                                                  Margin="0,0,6,6" Click="FormaPagamento_Click" Content="💵 Dinheiro"/>
                                    <ToggleButton x:Name="BtnPix" Tag="Pix" Style="{StaticResource TogglePagamento}"
                                                  Margin="3,0,3,6" Click="FormaPagamento_Click" Content="📱 Pix"/>
                                    <ToggleButton x:Name="BtnDebito" Tag="CartaoDebito" Style="{StaticResource TogglePagamento}"
                                                  Margin="6,0,0,6" Click="FormaPagamento_Click" Content="💳 Débito"/>
                                    <ToggleButton x:Name="BtnCredito" Tag="CartaoCredito" Style="{StaticResource TogglePagamento}"
                                                  Margin="0,0,6,0" Click="FormaPagamento_Click" Content="💳 Crédito"/>
                                    <ToggleButton x:Name="BtnBoleto" Tag="Boleto" Style="{StaticResource TogglePagamento}"
                                                  Margin="3,0,3,0" Click="FormaPagamento_Click" Content="📄 Boleto"/>
                                </UniformGrid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource LabelCampo}" Text="Valor deste pagamento (R$)"/>
                                        <TextBox x:Name="TxtValorPagamento" Style="{StaticResource TextBoxNumerico}"
                                                 TextChanged="TxtValorPagamento_TextChanged"/>
                                    </StackPanel>
                                    <StackPanel x:Name="PainelRecebido" Grid.Column="2" Visibility="Collapsed">
                                        <TextBlock Style="{StaticResource LabelCampo}" Text="Valor recebido (R$)"/>
                                        <TextBox x:Name="TxtValorRecebido" Style="{StaticResource TextBoxNumerico}"
                                                 TextChanged="TxtValorRecebido_TextChanged"/>
                                    </StackPanel>
                                    <StackPanel x:Name="PainelParcelas" Grid.Column="2" Visibility="Collapsed">
                                        <TextBlock Style="{StaticResource LabelCampo}" Text="Parcelas"/>
                                        <ComboBox x:Name="CmbParcelas" Style="{StaticResource ComboBoxModerno}"/>
                                    </StackPanel>
                                </Grid>
                                <TextBlock x:Name="TxtInfoTroco" Margin="0,8,0,0" FontSize="11"
                                           Foreground="{StaticResource VerdeSucessoBrush}" Visibility="Collapsed"/>
                                <Button Style="{StaticResource BotaoSecundario}" Content="+ Adicionar pagamento"
                                        HorizontalAlignment="Left" Margin="0,12,0,0" Click="BtnAdicionarPagamento_Click"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- Resumo lateral -->
            <Border Grid.Column="1" Background="White" CornerRadius="10">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" BlurRadius="10" Opacity="0.08"/>
                </Border.Effect>
                <Grid Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Resumo da Venda" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>
                        <Border Height="1" Background="{StaticResource CinzaMedioBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" VerticalAlignment="Top" Margin="0,14,0,0">
                        <TextBlock Style="{StaticResource LabelCampo}" Text="Observações"/>
                        <TextBox x:Name="TxtObservacoes" Style="{StaticResource TextBoxModerno}"
                                 Height="72" TextWrapping="Wrap" AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" VerticalAlignment="Bottom">
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="Subtotal:" FontSize="13" Foreground="{StaticResource CinzaTextoBrush}"/>
                            <TextBlock HorizontalAlignment="Right" FontSize="13"
                                       Text="{Binding Subtotal, Converter={StaticResource MoedaConverter}}"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <TextBlock Text="Desconto:" FontSize="13" Foreground="{StaticResource CinzaTextoBrush}" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <ComboBox x:Name="CmbTipoDesconto" Width="52" Margin="0,0,6,0"
                                          Style="{StaticResource ComboBoxModerno}"
                                          SelectionChanged="CmbTipoDesconto_SelectionChanged">
                                    <ComboBoxItem Content="R$" IsSelected="True"/>
                                    <ComboBoxItem Content="%"/>
                                </ComboBox>
                                <TextBox x:Name="TxtDesconto" Width="82" Style="{StaticResource TextBoxNumerico}"
                                         Text="0" TextChanged="TxtDesconto_TextChanged"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock x:Name="TxtDescontoEquivalente" FontSize="11" HorizontalAlignment="Right"
                                   Foreground="{StaticResource CinzaTextoBrush}" Margin="0,0,0,8"/>

                        <Border Height="1" Background="{StaticResource CinzaMedioBrush}" Margin="0,8,0,10"/>

                        <Grid Margin="0,0,0,4">
                            <TextBlock Text="TOTAL:" FontSize="17" FontWeight="Bold"/>
                            <TextBlock HorizontalAlignment="Right" FontSize="20" FontWeight="Bold"
                                       Foreground="{StaticResource AmareloPrimarioBrush}"
                                       Text="{Binding Total, Converter={StaticResource MoedaConverter}}"/>
                        </Grid>
                        <TextBlock Margin="0,0,0,14" FontSize="12" Foreground="{StaticResource CinzaTextoBrush}">
                            <Run Text="{Binding TotalItens}"/>
                            <Run Text=" item(ns)"/>
                        </TextBlock>

                        <Button x:Name="BtnAcaoPrincipal" Style="{StaticResource BotaoPrimario}"
                                Content="Continuar → Cliente" FontSize="14" Padding="16,12"
                                Click="BtnAcaoPrincipal_Click"/>
                        <Button x:Name="BtnConcluirVenda" Style="{StaticResource BotaoSucesso}"
                                Content="✓  Concluir Venda" FontSize="14" Padding="16,12" Margin="0,8,0,0"
                                Visibility="Collapsed" IsEnabled="False" Click="BtnConcluirVenda_Click"/>
                        <Button Style="{StaticResource BotaoSecundario}" Content="Cancelar venda"
                                Margin="0,8,0,0" Click="BtnFechar_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
