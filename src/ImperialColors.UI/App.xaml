<Application x:Class="ImperialColors.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ImperialColors.UI.Converters"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/AppTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Conversores globais pt-BR -->
            <conv:MoedaConverter x:Key="MoedaConverter"/>
            <conv:DataConverter x:Key="DataConverter"/>
            <conv:DataHoraConverter x:Key="DataHoraConverter"/>
            <conv:QuantidadeUnidadeConverter x:Key="QuantidadeUnidadeConverter"/>
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
            <conv:NullToVisibilityConverter x:Key="NullToVisibility"/>

            <!-- Template padrão para ComboBox de entidades com propriedade Nome -->
            <DataTemplate x:Key="ComboBoxNomeTemplate">
                <TextBlock Text="{Binding Nome}" FontSize="13"/>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
