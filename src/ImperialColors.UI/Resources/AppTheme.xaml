<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:helpers="clr-namespace:ImperialColors.UI.Helpers">

    <!-- Cores principais -->
    <Color x:Key="AmareloPrimario">#F5C200</Color>
    <Color x:Key="AmareloClaro">#FFF0A0</Color>
    <Color x:Key="AmareloEscuro">#D4A800</Color>
    <Color x:Key="BrancoFundo">#FFFFFF</Color>
    <Color x:Key="CinzaClaro">#F8F9FA</Color>
    <Color x:Key="CinzaMedio">#E9ECEF</Color>
    <Color x:Key="CinzaTexto">#6C757D</Color>
    <Color x:Key="PretoPrimario">#212529</Color>
    <Color x:Key="VerdeSucesso">#28A745</Color>
    <Color x:Key="VermelhoErro">#DC3545</Color>
    <Color x:Key="AzulInfo">#17A2B8</Color>
    <Color x:Key="AzulPrimario">#1565C0</Color>
    <Color x:Key="LaranjaAviso">#FD7E14</Color>
    <Color x:Key="MenuLateral">#1A1A2E</Color>
    <Color x:Key="MenuLateralHover">#2D2D4E</Color>
    <Color x:Key="MenuItemAtivoFundo">#28284A</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="AmareloPrimarioBrush" Color="{StaticResource AmareloPrimario}"/>
    <SolidColorBrush x:Key="AmareloEscuroBrush" Color="{StaticResource AmareloEscuro}"/>
    <SolidColorBrush x:Key="AmareloClaroBrush" Color="{StaticResource AmareloClaro}"/>
    <SolidColorBrush x:Key="BrancoFundoBrush" Color="{StaticResource BrancoFundo}"/>
    <SolidColorBrush x:Key="CinzaClaroBrush" Color="{StaticResource CinzaClaro}"/>
    <SolidColorBrush x:Key="CinzaMedioBrush" Color="{StaticResource CinzaMedio}"/>
    <SolidColorBrush x:Key="CinzaTextoBrush" Color="{StaticResource CinzaTexto}"/>
    <SolidColorBrush x:Key="PretoPrimarioBrush" Color="{StaticResource PretoPrimario}"/>
    <SolidColorBrush x:Key="VerdeSucessoBrush" Color="{StaticResource VerdeSucesso}"/>
    <SolidColorBrush x:Key="VermelhoErroBrush" Color="{StaticResource VermelhoErro}"/>
    <SolidColorBrush x:Key="AzulInfoBrush" Color="{StaticResource AzulInfo}"/>
    <SolidColorBrush x:Key="AzulPrimarioBrush" Color="{StaticResource AzulPrimario}"/>
    <SolidColorBrush x:Key="LaranjaAvisoBrush" Color="{StaticResource LaranjaAviso}"/>
    <SolidColorBrush x:Key="MenuLateralBrush" Color="{StaticResource MenuLateral}"/>
    <SolidColorBrush x:Key="MenuLateralHoverBrush" Color="{StaticResource MenuLateralHover}"/>
    <SolidColorBrush x:Key="MenuItemAtivoFundoBrush" Color="{StaticResource MenuItemAtivoFundo}"/>

    <FontFamily x:Key="FontePrimaria">Segoe UI</FontFamily>

    <!-- Dimensões padronizadas de inputs e filtros -->
    <sys:Double xmlns:sys="clr-namespace:System;assembly=mscorlib" x:Key="AlturaInputPadrao">38</sys:Double>
    <Thickness x:Key="PaddingInputPadrao">10,5,10,5</Thickness>
    <Thickness x:Key="PaddingInputFiltro">40,5,10,5</Thickness>

    <!-- Scrollbar minimalista -->
    <Style x:Key="ScrollBarMinimalThumb" TargetType="Thumb">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border Background="#C5CAD1" CornerRadius="4" Margin="1"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ScrollBarMinimal" TargetType="ScrollBar">
        <Setter Property="Width" Value="8"/>
        <Setter Property="MinWidth" Value="8"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb Style="{StaticResource ScrollBarMinimalThumb}"/>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto"/>
                <Setter Property="Height" Value="8"/>
                <Setter Property="MinHeight" Value="8"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ScrollViewerComMargem" TargetType="ScrollViewer">
        <Setter Property="Padding" Value="4,4,12,4"/>
        <Setter Property="Margin" Value="8"/>
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollViewer">
                    <Grid Background="{TemplateBinding Background}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                Grid.Column="0" Grid.Row="0"
                                                Margin="{TemplateBinding Padding}"
                                                Content="{TemplateBinding Content}"
                                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                                CanContentScroll="{TemplateBinding CanContentScroll}"/>
                        <ScrollBar x:Name="PART_VerticalScrollBar"
                                   Grid.Column="1" Grid.Row="0"
                                   Style="{StaticResource ScrollBarMinimal}"
                                   Orientation="Vertical"
                                   Maximum="{TemplateBinding ScrollableHeight}"
                                   ViewportSize="{TemplateBinding ViewportHeight}"
                                   Value="{TemplateBinding VerticalOffset}"
                                   Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        <ScrollBar x:Name="PART_HorizontalScrollBar"
                                   Grid.Column="0" Grid.Row="1"
                                   Style="{StaticResource ScrollBarMinimal}"
                                   Orientation="Horizontal"
                                   Maximum="{TemplateBinding ScrollableWidth}"
                                   ViewportSize="{TemplateBinding ViewportWidth}"
                                   Value="{TemplateBinding HorizontalOffset}"
                                   Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TextBox -->
    <Style x:Key="TextBoxModerno" TargetType="TextBox">
        <Setter Property="FontFamily" Value="{StaticResource FontePrimaria}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Height" Value="{StaticResource AlturaInputPadrao}"/>
        <Setter Property="MinHeight" Value="{StaticResource AlturaInputPadrao}"/>
        <Setter Property="Padding" Value="{StaticResource PaddingInputPadrao}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource CinzaMedioBrush}"/>
        <Setter Property="Background" Value="{StaticResource BrancoFundoBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource PretoPrimarioBrush}"/>
        <Setter Property="CaretBrush" Value="{StaticResource PretoPrimarioBrush}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource AmareloClaroBrush}"/>
        <Setter Property="SelectionTextBrush" Value="{StaticResource PretoPrimarioBrush}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Borda"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Focusable="False"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden"
                                      CanContentScroll="False"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Borda" Property="BorderBrush" Value="{StaticResource AmareloPrimarioBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Borda" Property="BorderBrush" Value="{StaticResource AmareloEscuroBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.65"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TextBoxMultilinha" TargetType="TextBox">
        <Setter Property="FontFamily" Value="{StaticResource FontePrimaria}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="MinHeight" Value="80"/>
        <Setter Property="Padding" Value="10,8,10,8"/>
        <Setter Property="VerticalContentAlignment" Value="Top"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource CinzaMedioBrush}"/>
        <Setter Property="Background" Value="{StaticResource BrancoFundoBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource PretoPrimarioBrush}"/>
        <Setter Property="CaretBrush" Value="{StaticResource PretoPrimarioBrush}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource AmareloClaroBrush}"/>
        <Setter Property="SelectionTextBrush" Value="{StaticResource PretoPrimarioBrush}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="AcceptsReturn" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Borda"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}"
                            MinHeight="{TemplateBinding MinHeight}"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Focusable="False"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Auto"
                                      CanContentScroll="False"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Borda" Property="BorderBrush" Value="{StaticResource AmareloPrimarioBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Borda" Property="BorderBrush" Value="{StaticResource AmareloEscuroBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.65"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TextBoxFiltro" TargetType="TextBox" BasedOn="{StaticResource TextBoxModerno}">
        <Setter Property="Padding" Value="{StaticResource PaddingInputFiltro}"/>
    </Style>

    <!-- DatePicker alinhado aos TextBox -->
    <Style x:Key="DatePickerModerno" TargetType="DatePicker">
        <Setter Property="helpers:DatePickerSyncHelper.Enable" Value="True"/>
        <Setter Property="FontFamily" Value="{StaticResource FontePrimaria}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Height" Value="{StaticResource AlturaInputPadrao}"/>
        <Setter Property="MinHeight" Value="{StaticResource AlturaInputPadrao}"/>
        <Setter Property="MinWidth" Value="176"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="BorderBrush" Value="{StaticResource CinzaMedioBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="{StaticResource BrancoFundoBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource PretoPrimarioBrush}"/>
        <Setter Property="SelectedDateFormat" Value="Short"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DatePicker">
                    <Border x:Name="Borda"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            ClipToBounds="False"
                            SnapsToDevicePixels="True">
                        <Grid x:Name="GridRoot" SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="34"/>
                            </Grid.ColumnDefinitions>

                            <DatePickerTextBox x:Name="PART_TextBox"
                                               Grid.Column="0"
                                               Grid.ColumnSpan="1"
                                               Margin="8,0,0,0"
                                               MinWidth="100"
                                               VerticalContentAlignment="Center"
                                               HorizontalContentAlignment="Stretch"
                                               HorizontalAlignment="Stretch"
                                               Background="Transparent"
                                               BorderThickness="0"
                                               Focusable="{TemplateBinding Focusable}"
                                               FontFamily="{TemplateBinding FontFamily}"
                                               FontSize="{TemplateBinding FontSize}"
                                               Foreground="{TemplateBinding Foreground}"/>

                            <Button x:Name="PART_Button"
                                    Grid.Column="1"
                                    TabIndex="2"
                                    Width="34"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Focusable="False"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Stretch">
                                <TextBlock Text="&#x1F4C5;" FontSize="14"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Button>

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding ElementName=GridRoot}"
                                   StaysOpen="False"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Borda" Property="BorderBrush" Value="{StaticResource AmareloEscuroBrush}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Borda" Property="BorderBrush" Value="{StaticResource AmareloPrimarioBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.65"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Resources>
            <Style TargetType="{x:Type DatePickerTextBox}">
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type DatePickerTextBox}">
                            <Grid Background="Transparent">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="WatermarkStates">
                                        <VisualState x:Name="Unwatermarked"/>
                                        <VisualState x:Name="Watermarked">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="PART_TextBox"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="0" Duration="0:0:0"/>
                                                <DoubleAnimation Storyboard.TargetName="PART_Watermark"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="1" Duration="0:0:0"/>
                                            </Storyboard>
                                        </VisualState>
                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>

                                <Grid x:Name="WatermarkWrapper">
                                    <TextBox x:Name="PART_TextBox"
                                             BorderThickness="0"
                                             Background="Transparent"
                                             Padding="0,0,2,0"
                                             VerticalContentAlignment="Center"
                                             HorizontalAlignment="Stretch"
                                             HorizontalContentAlignment="Left"
                                             MinWidth="90"
                                             Focusable="{TemplateBinding Focusable}"
                                             FontFamily="{TemplateBinding FontFamily}"
                                             FontSize="{TemplateBinding FontSize}"
                                             Foreground="{TemplateBinding Foreground}"
                                             CaretBrush="{TemplateBinding Foreground}"/>
                                    <ContentControl x:Name="PART_Watermark"
                                                    IsTabStop="False"
                                                    IsHitTestVisible="False"
                                                    Opacity="0"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Left"
                                                    Margin="0,0,0,0"/>
                                </Grid>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Style.Resources>
    </Style>

    <Style x:Key="PasswordBoxModerno" TargetType="PasswordBox">
        <Setter Property="FontFamily" Value="{StaticResource FontePrimaria}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Height" Value="{StaticResource AlturaInputPadrao}"/>
        <Setter Property="MinHeight" Value="{StaticResource AlturaInputPadrao}"/>
        <Setter Property="Padding" Value="{StaticResource PaddingInputPadrao}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource CinzaMedioBrush}"/>
        <Setter Property="Background" Value="{StaticResource BrancoFundoBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource PretoPrimarioBrush}"/>
        <Setter Property="CaretBrush" Value="{StaticResource PretoPrimarioBrush}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource AmareloClaroBrush}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border x:Name="Borda"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Focusable="False"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Hidden"
                                      CanContentScroll="False"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="Borda" Property="BorderBrush" Value="{StaticResource AmareloPrimarioBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Borda" Property="BorderBrush" Value="{StaticResource AmareloEscuroBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.65"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBox -->
    <Style x:Key="ComboBoxModerno" TargetType="ComboBox">
        <Setter Property="FontFamily" Value="{StaticResource FontePrimaria}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Height" Value="{StaticResource AlturaInputPadrao}"/>
        <Setter Property="MinHeight" Value="{StaticResource AlturaInputPadrao}"/>
        <Setter Property="Padding" Value="{StaticResource PaddingInputPadrao}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource CinzaMedioBrush}"/>
        <Setter Property="Background" Value="{StaticResource BrancoFundoBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource PretoPrimarioBrush}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="Toggle"
                                      Background="{TemplateBinding Background}"
                                      BorderBrush="{TemplateBinding BorderBrush}"
                                      BorderThickness="{TemplateBinding BorderThickness}"
                                      Focusable="False"
                                      Content="{x:Null}"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press"
                                      Cursor="Hand">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="BordaCombo" Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="28"/>
                                            </Grid.ColumnDefinitions>
                                            <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z"
                                                  Fill="{StaticResource CinzaTextoBrush}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="BordaCombo" Property="BorderBrush" Value="{StaticResource AmareloEscuroBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <ContentPresenter x:Name="ContentSite"
                                          IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                          Margin="10,5,28,5"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"/>
                        <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                            <Border Background="White" BorderBrush="{StaticResource CinzaMedioBrush}"
                                    BorderThickness="1" CornerRadius="6" MinWidth="{TemplateBinding ActualWidth}"
                                    MaxHeight="240" Padding="4">
                                <ScrollViewer Style="{StaticResource ScrollViewerComMargem}" Margin="0">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Botão primário -->
    <Style x:Key="BotaoPrimario" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource FontePrimaria}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource PretoPrimarioBrush}"/>
        <Setter Property="Background" Value="{StaticResource AmareloPrimarioBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="BotaoBorder" Background="{TemplateBinding Background}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <Border.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="BotaoBorder" Property="Background" Value="{StaticResource AmareloEscuroBrush}"/>
                            <Setter TargetName="BotaoBorder" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect ShadowDepth="1" BlurRadius="6" Opacity="0.18" Color="#000000"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="BotaoBorder" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Botão secundário -->
    <Style x:Key="BotaoSecundario" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource FontePrimaria}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource CinzaTextoBrush}"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource CinzaMedioBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="BotaoBorder" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="BotaoBorder" Property="Background" Value="{StaticResource CinzaClaroBrush}"/>
                            <Setter TargetName="BotaoBorder" Property="BorderBrush" Value="{StaticResource AmareloPrimarioBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="BotaoBorder" Property="Background" Value="{StaticResource CinzaMedioBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="BotaoPerigo" TargetType="Button" BasedOn="{StaticResource BotaoPrimario}">
        <Setter Property="Background" Value="{StaticResource VermelhoErroBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#C82333"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="BotaoSucesso" TargetType="Button" BasedOn="{StaticResource BotaoPrimario}">
        <Setter Property="Background" Value="{StaticResource VerdeSucessoBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#218838"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Color x:Key="WhatsAppVerde">#25D366</Color>
    <SolidColorBrush x:Key="WhatsAppVerdeBrush" Color="{StaticResource WhatsAppVerde}"/>

    <Style x:Key="BotaoWhatsApp" TargetType="Button" BasedOn="{StaticResource BotaoPrimario}">
        <Setter Property="Background" Value="{StaticResource WhatsAppVerdeBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#1EBE57"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Card -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BrancoFundoBrush}"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect ShadowDepth="1" BlurRadius="10" Opacity="0.08" Color="#000000"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Card de submódulo (Configurações) -->
    <Style x:Key="SubmoduloCard" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0,0,12,12"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Stretch"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="CardBorder" Background="White" CornerRadius="8"
                            BorderBrush="{StaticResource CinzaMedioBrush}" BorderThickness="1"
                            Padding="16" MinHeight="88">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="CardBorder" Property="Background" Value="{StaticResource CinzaClaroBrush}"/>
                            <Setter TargetName="CardBorder" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect ShadowDepth="2" BlurRadius="12" Opacity="0.12" Color="#000000"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="CardBorder" Property="Background" Value="#FFFEF5"/>
                        </Trigger>
                        <DataTrigger Binding="{Binding Path=(helpers:NavMenuHelper.IsActive), RelativeSource={RelativeSource Self}}" Value="True">
                            <Setter TargetName="CardBorder" Property="BorderBrush" Value="{StaticResource AmareloPrimarioBrush}"/>
                            <Setter TargetName="CardBorder" Property="BorderThickness" Value="2"/>
                            <Setter TargetName="CardBorder" Property="Background" Value="#FFFEF5"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- DataGrid -->
    <Style x:Key="DataGridModerno" TargetType="DataGrid">
        <Setter Property="FontFamily" Value="{StaticResource FontePrimaria}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource CinzaMedioBrush}"/>
        <Setter Property="AlternatingRowBackground" Value="{StaticResource CinzaClaroBrush}"/>
        <Setter Property="RowBackground" Value="White"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="CanUserAddRows" Value="False"/>
        <Setter Property="CanUserDeleteRows" Value="False"/>
        <Setter Property="SelectionMode" Value="Single"/>
        <Setter Property="AutoGenerateColumns" Value="False"/>
        <Setter Property="RowHeight" Value="38"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
        <Setter Property="EnableRowVirtualization" Value="True"/>
        <Setter Property="EnableColumnVirtualization" Value="True"/>
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
        <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
    </Style>

    <Style x:Key="DataGridHeaderModerno" TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource CinzaClaroBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource CinzaTextoBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="BorderBrush" Value="{StaticResource CinzaMedioBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,2"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style x:Key="LabelCampo" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontePrimaria}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource CinzaTextoBrush}"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
    </Style>

    <Style x:Key="TituloModulo" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FontePrimaria}"/>
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource PretoPrimarioBrush}"/>
    </Style>

    <Style x:Key="BadgeVerde" TargetType="Border">
        <Setter Property="Background" Value="#D4EDDA"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="8,3"/>
    </Style>
    <Style x:Key="BadgeAmarelo" TargetType="Border">
        <Setter Property="Background" Value="#FFF3CD"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="8,3"/>
    </Style>
    <Style x:Key="BadgeVermelho" TargetType="Border">
        <Setter Property="Background" Value="#F8D7DA"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="8,3"/>
    </Style>

    <Style x:Key="CheckBoxModerno" TargetType="CheckBox">
        <Setter Property="FontFamily" Value="{StaticResource FontePrimaria}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource PretoPrimarioBrush}"/>
        <Setter Property="Cursor" Value="Hand"/>
    </Style>

    <Style x:Key="TextBoxNumerico" TargetType="TextBox" BasedOn="{StaticResource TextBoxModerno}">
        <Setter Property="TextAlignment" Value="Right"/>
    </Style>

    <!-- Botão menu lateral -->
    <Style x:Key="MenuButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="14,11"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Margin" Value="0,2,0,2"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="IndicadorAtivo" Width="3" HorizontalAlignment="Left"
                                Background="{StaticResource AmareloPrimarioBrush}"
                                CornerRadius="2" Margin="0,6,0,6" Visibility="Collapsed"/>
                        <Border x:Name="FundoBotao" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}" Margin="4,0,0,0">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="FundoBotao" Property="Background" Value="{StaticResource MenuLateralHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="FundoBotao" Property="Background" Value="#3A3A5C"/>
                        </Trigger>
                        <DataTrigger Binding="{Binding Path=(helpers:NavMenuHelper.IsActive), RelativeSource={RelativeSource Self}}" Value="True">
                            <Setter TargetName="IndicadorAtivo" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="FundoBotao" Property="Background" Value="{StaticResource MenuItemAtivoFundoBrush}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MenuButtonDestaque" TargetType="Button" BasedOn="{StaticResource MenuButton}">
        <Setter Property="Foreground" Value="{StaticResource AmareloPrimarioBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- Toggle pagamento PDV -->
    <Style x:Key="TogglePagamento" TargetType="ToggleButton">
        <Setter Property="FontFamily" Value="{StaticResource FontePrimaria}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource PretoPrimarioBrush}"/>
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource CinzaMedioBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="Borda" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6" Padding="10,8">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Borda" Property="Background" Value="{StaticResource AmareloPrimarioBrush}"/>
                            <Setter TargetName="Borda" Property="BorderBrush" Value="{StaticResource AmareloEscuroBrush}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Borda" Property="BorderBrush" Value="{StaticResource AmareloEscuroBrush}"/>
                            <Setter TargetName="Borda" Property="Background" Value="{StaticResource CinzaClaroBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
